      <script>
        function toggleFaq(card) {
            const btn = card.querySelector('.faq-question');
            const answer = card.querySelector('.faq-answer');
            const toggle = card.querySelector('.faq-toggle');
            
            if (!btn || !answer || !toggle) return;
            
            const isExpanded = btn.getAttribute('aria-expanded') === 'true';
            
            btn.setAttribute('aria-expanded', !isExpanded);
            answer.hidden = isExpanded;
            toggle.style.transform = isExpanded ? 'rotate(0deg)' : 'rotate(180deg)';
            
            // Optional: Close others
            if (!isExpanded) {
                document.querySelectorAll('.faq-card').forEach(otherCard => {
                    if (otherCard !== card) {
                        const otherBtn = otherCard.querySelector('.faq-question');
                        const otherAnswer = otherCard.querySelector('.faq-answer');
                        const otherToggle = otherCard.querySelector('.faq-toggle');
                        if (otherBtn && otherAnswer && otherToggle) {
                            otherBtn.setAttribute('aria-expanded', 'false');
                            otherAnswer.hidden = true;
                            otherToggle.style.transform = 'rotate(0deg)';
                        }
                    }
                });
            }
        }
      </script>

