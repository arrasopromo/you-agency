  <meta charset="utf-8" />
  <title>Checkout - Engajamento</title>
  <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1, user-scalable=no" />
  <link href="/css/style.css?v=9" rel="stylesheet" />
  <link href="/css/badges.css" rel="stylesheet" />
  <link href="/css/perfil.css" rel="stylesheet" />
  <!-- Testimonials CSS -->
  <link href="/css/testimonials.css" rel="stylesheet" />
  <link href="/css/why-us.css?v=5" rel="stylesheet" />
  <link rel="icon" type="image/png" href="/images/logo.png" />
  
  <style>
    /* Footer Fix */
    body {
      display: flex;
      flex-direction: column;
      min-height: 100vh;
      overflow-x: hidden; /* Previne scroll horizontal global */
      width: 100%;
    }
    img {
      max-width: 100%;
      height: auto;
    }
    .checkout-page {
      flex: 1;
      display: flex;
      flex-direction: column;
      width: 100%; /* Garante que não exceda viewport */
      overflow-x: hidden; /* Reforço */
    }
    .main-content {
      flex: 1;
      width: 100%;
    }

    /* Estilos específicos para o seletor de contexto (Topo) */
    .service-context-selector {
      display: flex;
      justify-content: center;
      gap: 1rem;
      margin-bottom: 2rem;
      padding: 0 1rem;
      flex-wrap: wrap;
    }
    
    /* Base Button Style */
    .service-selector-btn {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 0.5rem;
      padding: 0.75rem 1.5rem;
      background: var(--bg-secondary);
      border: 1px solid var(--border-color);
      border-radius: 999px; /* Pill shape */
      font-weight: 700;
      color: var(--text-primary);
      cursor: pointer;
      transition: all 0.2s ease;
      font-size: 0.95rem;
      box-shadow: var(--shadow-sm);
      white-space: nowrap;
    }
    
    body.theme-light .service-selector-btn {
      background: #ffffff;
      color: #334155; /* Slate 700 - Better contrast */
      border-color: #cbd5e1; /* Slate 300 */
    }

    .service-selector-btn:hover {
      border-color: var(--primary-purple);
      transform: translateY(-2px);
      box-shadow: var(--shadow-md);
    }
    
    /* FIX: More specific selector for active button in light mode to override the default light mode background */
    .service-selector-btn.active,
    body.theme-light .service-selector-btn.active {
      background: var(--instagram-gradient) !important;
      color: white !important;
      border: 1px solid transparent;
      box-shadow: 0 4px 12px rgba(220, 39, 67, 0.3);
    }

    .service-selector-btn svg {
      width: 18px;
      height: 18px;
      flex-shrink: 0;
    }

    /* Plans Grid */
    .plans-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
        gap: 1rem;
        width: 100%;
        max-width: 900px;
        margin: 0 auto;
    }

    .plan-card {
        background: var(--bg-secondary);
        border: 2px solid var(--border-color);
        border-radius: 12px;
        padding: 1rem;
        cursor: pointer;
        transition: all 0.2s ease;
        text-align: center;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        min-height: 100px;
        position: relative;
        overflow: hidden;
    }

    .plan-card:hover {
        border-color: var(--primary-purple);
        transform: translateY(-2px);
        box-shadow: var(--shadow-md);
    }

    .plan-card.active {
        border-color: #db2777;
        background: rgba(219, 39, 119, 0.1);
        box-shadow: 0 4px 12px rgba(219, 39, 119, 0.15);
    }
    
    body.theme-light .plan-card.active {
        background: #fdf2f8;
    }

    .plan-quantity {
        font-size: 1.5rem;
        font-weight: 800;
        color: var(--text-primary);
        line-height: 1.2;
    }

    .plan-price {
        font-size: 1rem;
        color: var(--primary-purple);
        font-weight: 600;
        margin-top: 0.25rem;
    }
    
    .plan-unit {
        font-size: 0.8rem;
        color: var(--text-secondary);
        font-weight: 500;
        margin-top: -0.2rem;
    }

    /* Specific Styles for Service Type Buttons (The ones to change) */
    .type-btn {
      background: #1e1e1e; /* Dark theme */
      color: #ffffff;
      border: 1px solid rgba(255,255,255,0.1);
      font-size: 0.8rem; /* Smaller font */
      padding: 0.5rem 1rem; /* Smaller padding */
      height: auto;
      min-width: 0;
    }

    .type-btn:hover {
        background: #333;
    }
    
    .type-btn.active {
        background: var(--instagram-gradient);
        border-color: transparent;
    }

    /* Custom Buy Button Style */
    .buy-btn-custom {
      background: var(--primary-purple) !important;
      font-size: 0.85rem !important;
      padding: 0.5rem 1.5rem !important;
      height: auto !important;
      min-height: 0 !important;
      border-radius: 999px !important;
      box-shadow: none !important;
      color: white !important;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      font-weight: 700;
    }
    .buy-btn-custom:hover {
      background: var(--dark-purple) !important;
      transform: translateY(-2px);
    }

    /* Horizontal Layout for Type Buttons */
    #tipoCards {
      display: flex;
      flex-direction: row;
      gap: 0.75rem;
      overflow-x: auto;
      padding-bottom: 1rem;
      margin-bottom: 1.5rem;
      scrollbar-width: none; /* Firefox */
      -ms-overflow-style: none; /* IE/Edge */
      justify-content: center; /* Center them */
      flex-wrap: wrap; /* Wrap on small screens or scroll? User image showed row. Let's wrap for better usability unless specifically scroll. */
    }
    
    /* User asked for "smaller", "like I put on computer". Assuming horizontal pills. */
    /* If many options, wrap is safer than scroll for desktop. */

    /* Ferramenta Exclusiva Image Size */
    .exclusive-img-container {
        max-width: 320px;
        margin: 0 auto;
        transition: max-width 0.3s ease;
    }
    @media (min-width: 768px) {
      .exclusive-img-container {
        max-width: 500px !important; /* Slightly smaller on desktop */
      }
    }
    
    #ferramentaExclusivaSection img {
        transition: all 0.3s ease;
        width: 100%;
        height: auto;
    }

    /* Services Grid (2 Columns Mobile) */
    .services-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
      gap: 1rem;
    }
    @media (max-width: 640px) {
      .services-grid {
        grid-template-columns: repeat(2, 1fr);
        gap: 0.35rem; /* Reduced gap for wider cards */
      }
      /* Reduce container padding on mobile to maximize width */
      .container, .section-with-bg {
        padding-left: 0.5rem !important;
        padding-right: 0.5rem !important;
      }
    }

    /* Override Plan Card for this page */
    .plan-card .plan-quantity {
      font-size: 1.1rem; /* Smaller numbers as requested */
    }
    
    /* Placeholder size adjustment to match servicos-instagram */
    .select-input::placeholder, #usernameCheckoutInput::placeholder {
        font-size: 0.95rem !important;
        opacity: 0.7;
    }

    /* Section Background Style */
    .section-with-bg {
        background: rgba(255, 255, 255, 0.03); /* Subtle background */
        border: 1px solid rgba(255, 255, 255, 0.05);
        border-radius: 20px;
        padding: 1.5rem;
        margin-bottom: 2rem;
        box-shadow: 0 4px 6px rgba(0, 0, 0, 0.05);
    }
    @media (max-width: 640px) {
        .section-with-bg {
            padding: 1rem;
            border-radius: 16px;
        }
    }

    /* Price Styles matching servicos-instagram */
    .price-old {
      text-decoration: line-through;
      color: #9ca3af; /* gray-400 */
      font-size: 0.85rem;
      margin-right: 0.25rem;
    }
    
    .price-new {
      color: #22c55e;
      font-weight: 700;
      font-size: 1rem;
    }
    
    /* Ensure card title matches servicos-instagram */
    .plan-card .card-title {
        font-size: 0.95rem;
        font-weight: 600;
        color: var(--text-primary);
        line-height: 1.2;
        margin-bottom: 0.25rem;
    }

    /* Hide old type cards as we use direct buttons */
    body.theme-light .plan-card,
    body.theme-light .service-selector-btn {
        background: #ffffff;
    }
    
    /* Dark Mode Overrides for Plan Cards */
    body:not(.theme-light) .plan-card {
        background: var(--bg-secondary);
        border-color: var(--border-color);
    }

    #tipoCards {
      display: none !important;
    }
    
    /* Footer Fix Override */
    footer.footer {
      background: transparent !important;
      border-top: none !important;
      margin-top: 0 !important;
    }

    /* Stepper Styles */
    .stepper-container {
      display: flex;
      align-items: center;
      justify-content: center;
      margin-bottom: 2rem;
      width: 100%;
      max-width: 600px;
      margin-left: auto;
      margin-right: auto;
      padding: 0 1rem;
    }
    .step {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 0.5rem;
      position: relative;
      z-index: 2;
    }
    .step-circle {
      width: 32px;
      height: 32px;
      border-radius: 50%;
      background: var(--bg-secondary);
      border: 2px solid var(--border-color);
      color: var(--text-secondary);
      display: flex;
      align-items: center;
      justify-content: center;
      font-weight: 700;
      transition: all 0.3s ease;
    }
    .step.active .step-circle {
      background: var(--primary-purple);
      border-color: var(--primary-purple);
      color: #fff;
      box-shadow: 0 0 0 4px rgba(139, 92, 246, 0.2);
    }
    .step-label {
      font-size: 0.85rem;
      font-weight: 600;
      color: var(--text-secondary);
      transition: all 0.3s ease;
    }
    .step.active .step-label {
      color: var(--primary-purple);
    }
    .step-line {
      flex: 1;
      height: 2px;
      background: var(--border-color);
      margin: 0 -10px;
      position: relative;
      z-index: 1;
      top: -14px;
      transition: all 0.3s ease;
    }
    .step-line.active {
      background: var(--primary-purple);
    }
  </style>

  <!-- TRACK COMBO -->
