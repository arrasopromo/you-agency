<%
  let serverQueryString = '';
  if (typeof queryParams !== 'undefined' && queryParams) {
     const p = new URLSearchParams();
     ['utm_source', 'utm_medium', 'utm_campaign', 'utm_term', 'utm_content', 'gclid', 'fbclid'].forEach(k => {
