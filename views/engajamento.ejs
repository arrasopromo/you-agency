  <script>
    // Server-side UTMs passed to client
    window.SERVER_UTMS_QUERY = '<%- serverQueryString %>';

    // Persist UTMs to sessionStorage immediately
    try {
      // Merge Server UTMs into URL if missing (visual only, mostly)
      // But more importantly, merge into sessionStorage
      const currentParams = new URLSearchParams(window.location.search);
      const serverParams = new URLSearchParams(window.SERVER_UTMS_QUERY);
      
      const utms = {};
      
      // 1. From Server (Priority)
      serverParams.forEach((v, k) => { utms[k] = v; });
      
      // 2. From Client URL (Overwrites server if present? usually same)
      ['utm_source', 'utm_medium', 'utm_campaign', 'utm_term', 'utm_content', 'gclid', 'fbclid'].forEach(k => {
         const v = currentParams.get(k);
         if(v) utms[k] = v;
      });

      if (Object.keys(utms).length > 0) {
          // Merge with existing storage
          try {
             const existing = JSON.parse(sessionStorage.getItem('oppus_utms') || '{}');
             Object.assign(existing, utms);
             sessionStorage.setItem('oppus_utms', JSON.stringify(existing));
          } catch(e) {
             sessionStorage.setItem('oppus_utms', JSON.stringify(utms));
          }
      }
    } catch(_) {}

    window.__ENG_MODE__ = (location && location.pathname && location.pathname.indexOf('/engajamento') === 0);
    window.__PAGE_LANG__ = 'en';
    window.__DISABLE_PIX__ = true;
    window.currentPaymentMethod = 'credit_card';
    // Redirecionamento especГғВӯfico para Engajamento -> Instagram (com persistГғВӘncia de UTMs)
    document.addEventListener('DOMContentLoaded', function() {
      
      // Helper para recuperar UTMs da URL ou do Storage
      function getStoredUTMsQuery() {
        const currentParams = new URLSearchParams(window.location.search);
        // Ensure server params are considered if not in URL yet (e.g. if rewritten)
        const serverParams = new URLSearchParams(window.SERVER_UTMS_QUERY);
        serverParams.forEach((v, k) => {
            if (!currentParams.has(k)) currentParams.set(k, v);
        });

        const stored = sessionStorage.getItem('oppus_utms');
        if (stored) {
            try {
                const utms = JSON.parse(stored);
                Object.keys(utms).forEach(k => {
                    if (!currentParams.has(k)) {
                        currentParams.set(k, utms[k]);
                    }
                });
            } catch(e) {}
        }
        const qs = currentParams.toString();
        return qs ? ('?' + qs) : '';
    }

      if (window.__ENG_MODE__) {
        // Update links on load
        const fullQuery = getStoredUTMsQuery();
        
        // Update Instagram Button/Link
        const instaBtn = document.querySelector('.platform-btn.instagram');
        if (instaBtn) {
            // Se for link <a>
            if (instaBtn.tagName === 'A') {
                const base = instaBtn.getAttribute('href').split('?')[0];
                instaBtn.setAttribute('href', base + fullQuery);
            }
        }

        document.addEventListener('click', function(e) {
          // 1. BotГғВЈo Toggle da Plataforma
          var toggleBtn = e.target.closest('.platform-btn');
          if (toggleBtn) {
             e.preventDefault();

             var cardsDiv = document.getElementById('engajamentoServiceCards');
             var tiktokCard = document.getElementById('tiktokMaintenanceCard');
             var tutorialPlatform = document.getElementById('tutorialPlatform');
             if (tutorialPlatform) tutorialPlatform.style.display = 'none';

             if (toggleBtn.classList.contains('instagram')) {
                // Show Service Cards
                if (cardsDiv) {
                    if (cardsDiv.style.display === 'none') {
                        cardsDiv.style.display = 'grid';
                        setTimeout(() => {
                            cardsDiv.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
                        }, 100);
                    } else {
                        cardsDiv.style.display = 'none';
                    }
                }
                // Hide TikTok Card
                if (tiktokCard) tiktokCard.style.display = 'none';

             } else if (toggleBtn.classList.contains('tiktok')) {
                // Show TikTok Card
                if (tiktokCard) {
                    tiktokCard.style.display = 'block';
                    setTimeout(() => {
                        tiktokCard.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
                    }, 100);
                }
                // Hide Service Cards
                if (cardsDiv) cardsDiv.style.display = 'none';
             }
             return;
          }

          // 2. Qualquer link <a> apontando para /servicos-instagram
          var link = e.target.closest('a');
          if (link) {
            var href = link.getAttribute('href');
            if (href && href.includes('servicos-instagram')) {
               // Atualiza href dinamicamente antes de navegar
               const baseUrl = href.split('?')[0];
               const qs = getStoredUTMsQuery();
               // Se o link jГғВЎ tem query, a gente preserva?
               // A lГғВіgica getStoredUTMsQuery jГғВЎ pega tudo.
               // Vamos apenas substituir para garantir consistГғВӘncia
               link.setAttribute('href', baseUrl + qs);
            }
          }
        }, true);
      }
    });
  </script>
