          <h2 style="margin:0 0 8px; font-size:1rem;">Usuários Bloqueados</h2>
          <div style="display:flex; gap:8px; margin-bottom:12px;">
            <input type="text" id="blacklistInput" placeholder="Usuário (sem @)" style="flex:1; padding:6px; border:1px solid #ccc; border-radius:4px;">
            <button onclick="addToBlacklist()" style="padding:6px 12px; background:#dc3545; color:#fff; border:none; border-radius:4px; cursor:pointer;">Bloquear</button>
          </div>
          <ul id="blacklistList" style="list-style:none; padding:0; margin:0; max-height: 200px; overflow-y: auto;">
            <!-- Items via JS -->
          </ul>
          <script>
            async function loadBlacklist() {
              try {
                const res = await fetch('/api/blacklist');
                const data = await res.json();
                if(data.success) {
                  renderBlacklist(data.blacklist);
                }
              } catch(e) { console.error(e); }
            }

            function renderBlacklist(list) {
              const ul = document.getElementById('blacklistList');
              ul.innerHTML = '';
              if (list.length === 0) {
                ul.innerHTML = '<li style="color:#777; font-size:0.9rem; text-align:center;">Nenhum usuário bloqueado</li>';
                return;
              }
              list.forEach(item => {
                const li = document.createElement('li');
                li.style.display = 'flex';
                li.style.justifyContent = 'space-between';
                li.style.alignItems = 'center';
                li.style.padding = '6px 0';
                li.style.borderBottom = '1px solid #eee';
                
                const span = document.createElement('span');
                span.textContent = item.username;
                span.style.fontWeight = '500';
                
                const btn = document.createElement('button');
                btn.textContent = '✕';
                btn.style.background = 'transparent';
                btn.style.border = 'none';
                btn.style.color = '#dc3545';
                btn.style.cursor = 'pointer';
                btn.style.fontSize = '1.1rem';
                btn.title = 'Desbloquear';
                btn.onclick = () => removeFromBlacklist(item.username);
                
                li.appendChild(span);
                li.appendChild(btn);
                ul.appendChild(li);
              });
            }

            async function addToBlacklist() {
              const input = document.getElementById('blacklistInput');
              const username = input.value.trim();
              if(!username) return;
              
              try {
                const res = await fetch('/api/blacklist/add', {
                  method: 'POST',
                  headers: {'Content-Type': 'application/json'},
                  body: JSON.stringify({ username })
                });
                const data = await res.json();
                if(data.success) {
                  input.value = '';
                  loadBlacklist();
                } else {
                  alert('Erro ao bloquear: ' + (data.message || data.error));
                }
              } catch(e) { alert('Erro: ' + e.message); }
            }

            async function removeFromBlacklist(username) {
              if(!confirm('Desbloquear ' + username + '?')) return;
              try {
                const res = await fetch('/api/blacklist/remove', {
                  method: 'POST',
                  headers: {'Content-Type': 'application/json'},
                  body: JSON.stringify({ username })
                });
                const data = await res.json();
                if(data.success) {
                  loadBlacklist();
                } else {
                  alert('Erro ao desbloquear: ' + (data.message || data.error));
                }
              } catch(e) { alert('Erro: ' + e.message); }
            }

            loadBlacklist();
          </script>
        </div>
    </div>
    <% } %>
      <% } %>
    <% } %>

      
  </div>
  </div>
  <% if (isUnknownOrderIdView) { %>
  <div
    id="unknownOrderModal"
    class="unknown-order-modal"
    style="display:none; position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.5); z-index:2147483647; align-items:center; justify-content:center;"
    data-open-id="<%= (typeof openUnknownModal !== 'undefined' && openUnknownModal) ? String(openUnknownModal) : '' %>"
    data-default-provider="<%= (typeof openUnknownDefaultProvider !== 'undefined' && openUnknownDefaultProvider) ? String(openUnknownDefaultProvider) : '' %>"
    data-lock-provider="<%= (typeof openUnknownLockProvider !== 'undefined' && openUnknownLockProvider) ? String(openUnknownLockProvider) : '' %>"
  >
    <div style="background:white; padding:20px; border-radius:8px; width:100%; max-width:420px; max-height:calc(100vh - 92px); overflow:auto; box-shadow:0 4px 6px rgba(0,0,0,0.1); box-sizing:border-box;">
      <h3 style="margin-top:0; margin-bottom:15px;">Registrar OrderID</h3>
      <div id="unknownModalMeta" style="margin-bottom:12px; font-size:0.85rem; color:#555;">
        <div><strong>ID:</strong> <span id="unknownModalMetaId">-</span></div>
        <div><strong>Usuário:</strong> <span id="unknownModalMetaUser">-</span></div>
        <div><strong>Serviço:</strong> <span id="unknownModalMetaService">-</span></div>
      </div>
      <div style="margin-bottom:15px;">
        <label style="display:block; margin-bottom:5px; font-weight:bold;">Fornecedor:</label>
        <select id="unknownModalProvider" style="width:100%; padding:8px; border:1px solid #ddd; border-radius:4px;">
          <option value="fama24h">Fama24h</option>
          <option value="fama24h_views">Fama24h (Bump Views)</option>
          <option value="fama24h_likes">Fama24h (Bump Curtidas)</option>
          <option value="fornecedor_social">Fornecedor Social</option>
          <option value="fornecedor_social_likes">Fornecedor Social (Bump Curtidas)</option>
          <option value="worldsmm_comments">WorldSMM (Comentários)</option>
        </select>
      </div>
      <div style="margin-bottom:20px;">
        <label style="display:block; margin-bottom:5px; font-weight:bold;">Order ID(s):</label>
        <textarea id="unknownModalOrderId" rows="3" style="width:100%; padding:8px; border:1px solid #ddd; border-radius:4px; resize:vertical;" placeholder="Ex: 123456 ou 123456, 789012"></textarea>
      </div>
      <div style="display:flex; justify-content:flex-end; gap:10px;">
        <button type="button" onclick="closeUnknownOrderModal()" style="padding:8px 16px; background:#6c757d; color:white; border:none; border-radius:4px; cursor:pointer;">Cancelar</button>
        <button type="button" onclick="saveUnknownOrderInfo()" style="padding:8px 16px; background:#28a745; color:white; border:none; border-radius:4px; cursor:pointer;">Salvar</button>
      </div>
    </div>
  </div>
  <script>
    var currentUnknownOrderId = null;
    const HIDDEN_ORDERS_KEY = 'oppus_hidden_orders_v1';
    var unknownModalScrollY = 0;
    var unknownModalPrevBodyPosition = '';
    var unknownModalPrevBodyTop = '';
    var unknownModalPrevBodyWidth = '';
    var unknownModalPrevBodyOverflow = '';
    var unknownModalPrevHtmlOverflow = '';
    var unknownModalIsLocked = false;

    function setUnknownModalMeta(meta) {
      try {
        var idEl = document.getElementById('unknownModalMetaId');
        var userEl = document.getElementById('unknownModalMetaUser');
        var svcEl = document.getElementById('unknownModalMetaService');
        var m = meta || {};
        if (idEl) idEl.textContent = String(m.id || '-');
        if (userEl) userEl.textContent = String(m.user || '-');
        if (svcEl) svcEl.textContent = String(m.service || '-');
      } catch (_) {}
    }

    function setUnknownModalScrollLock(locked) {
      try {
        const body = document.body;
        const html = document.documentElement;
        if (!body || !html) return;
        if (locked) {
          if (unknownModalIsLocked) return;
          unknownModalScrollY = (typeof window.scrollY === 'number') ? window.scrollY : (html ? html.scrollTop : 0);
          unknownModalPrevBodyPosition = body.style.position || '';
          unknownModalPrevBodyTop = body.style.top || '';
          unknownModalPrevBodyWidth = body.style.width || '';
          unknownModalPrevBodyOverflow = body.style.overflow || '';
          unknownModalPrevHtmlOverflow = html.style.overflow || '';
          body.style.overflow = 'hidden';
          html.style.overflow = 'hidden';
          unknownModalIsLocked = true;
        } else {
          if (!unknownModalIsLocked) return;
          body.style.position = unknownModalPrevBodyPosition;
          body.style.top = unknownModalPrevBodyTop;
          body.style.left = '';
          body.style.right = '';
          body.style.width = unknownModalPrevBodyWidth;
          body.style.overflow = unknownModalPrevBodyOverflow;
          html.style.overflow = unknownModalPrevHtmlOverflow;
          unknownModalIsLocked = false;
          window.scrollTo(0, unknownModalScrollY || 0);
        }
      } catch(_) {}
    }

    function openUnknownOrderModal(orderId, defaultProvider, lockProvider, meta) {
      currentUnknownOrderId = orderId;
      const modal = document.getElementById('unknownOrderModal');
      const providerEl = document.getElementById('unknownModalProvider');
      const orderIdEl = document.getElementById('unknownModalOrderId');
      if (!modal) {
        return;
      }
      try {
        if (modal.parentNode !== document.body) {
          document.body.appendChild(modal);
        }
      } catch (_) {}
      setUnknownModalMeta(Object.assign({ id: orderId }, meta || {}));
      if (providerEl && defaultProvider) providerEl.value = defaultProvider;
      if (providerEl) providerEl.disabled = (String(lockProvider || '') === '1');
      if (orderIdEl) orderIdEl.value = '';
      try { modal.style.display = 'flex'; } catch (_) {}
      try { modal.classList.add('is-open'); } catch (_) {}
      try { setUnknownModalScrollLock(true); } catch(_) {}
      if (orderIdEl) {
        try { orderIdEl.focus({ preventScroll: true }); } catch(_) { try { orderIdEl.focus(); } catch(_) {} }
      }
      try { modal.scrollTop = 0; } catch(_) {}
    }

    function closeUnknownOrderModal() {
      const modal = document.getElementById('unknownOrderModal');
      if (modal) {
        try { modal.style.display = 'none'; } catch (_) {}
        try { modal.classList.remove('is-open'); } catch (_) {}
      }
      try { setUnknownModalScrollLock(false); } catch(_) {}
      const providerEl = document.getElementById('unknownModalProvider');
      if (providerEl) providerEl.disabled = false;
      setUnknownModalMeta(null);
      currentUnknownOrderId = null;
    }

    async function saveUnknownOrderInfo() {
      const provider = document.getElementById('unknownModalProvider').value;
      const orderIdRaw = document.getElementById('unknownModalOrderId').value;
      const tokens = String(orderIdRaw || '')
        .split(/[\s,;]+/g)
        .map(s => String(s || '').trim())
        .filter(Boolean);
      const payloadOrderId = tokens.length > 1 ? tokens : (tokens[0] || '');
      if (!payloadOrderId) {
        alert('Por favor, informe o Order ID do fornecedor.');
        return;
      }
      if (!currentUnknownOrderId) return;

      try {
        const res = await fetch('/api/admin/update-private-order', {
          method: 'POST',
          credentials: 'same-origin',
          headers: { 'Content-Type': 'application/json', 'Accept': 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
          body: JSON.stringify({
            id: currentUnknownOrderId,
            field: 'supplierInfo',
            value: { provider, orderId: payloadOrderId }
          })
        });
        const contentType = String(res.headers.get('content-type') || '');
        let data = null;
        if (contentType.includes('application/json')) {
          try { data = await res.json(); } catch (_) { data = null; }
        } else {
          const raw = await res.text();
          if (res.status === 401) {
            window.location.href = '/login';
            return;
          }
          throw new Error(raw || `HTTP ${res.status}`);
        }
        if (res.ok && data && data.ok) {
          window.location.reload();
        } else {
          if (res.status === 401) {
            window.location.href = '/login';
            return;
          }
          alert('Erro ao salvar: ' + ((data && data.error) || `HTTP ${res.status}`));
        }
      } catch (e) {
        alert('Erro de conexão: ' + (e && e.message ? e.message : e));
      } finally {
        closeUnknownOrderModal();
      }
    }

    function getHiddenOrdersSet() {
      try {
        const raw = localStorage.getItem(HIDDEN_ORDERS_KEY);
        const arr = raw ? JSON.parse(raw) : [];
        return new Set(Array.isArray(arr) ? arr.map(String) : []);
      } catch (_) {
        return new Set();
      }
    }

    function saveHiddenOrdersSet(set) {
      try {
        const arr = Array.from(set);
        localStorage.setItem(HIDDEN_ORDERS_KEY, JSON.stringify(arr));
      } catch (_) {}
    }

    function updateUnknownActionsSummary() {
      try {
        const hidden = getHiddenOrdersSet();
        const hiddenOnlyCb = document.getElementById('unknownShowHiddenOnly');
        const hiddenOnly = !!(hiddenOnlyCb && hiddenOnlyCb.checked);
        const rows = document.querySelectorAll('tr[data-id]');

        var visible = { orders: 0, total: 0, main: 0, world: 0, views: 0, likes: 0 };
        var hiddenAgg = { orders: 0, total: 0 };

        rows.forEach(function(tr){
          if (!tr) return;
          var id = String(tr.getAttribute('data-id') || '');
          var isHidden = !!(id && hidden.has(id));
          var btns = tr.querySelectorAll('.unknown-open-modal');
          if (!btns || !btns.length) return;

          var per = { total: 0, main: 0, world: 0, views: 0, likes: 0 };
          btns.forEach(function(b){
            var p = String(b.getAttribute('data-default-provider') || '').trim();
            per.total += 1;
            if (p === 'worldsmm_comments') per.world += 1;
            else if (p === 'fama24h_views') per.views += 1;
            else if (p === 'fama24h_likes' || p === 'fornecedor_social_likes') per.likes += 1;
            else per.main += 1;
          });

          if (isHidden) {
            hiddenAgg.orders += 1;
            hiddenAgg.total += per.total;
          } else {
            visible.orders += 1;
            visible.total += per.total;
            visible.main += per.main;
            visible.world += per.world;
            visible.views += per.views;
            visible.likes += per.likes;
          }
        });

        var elOrdersV = document.getElementById('unknownActionsOrdersVisible');
        var elTotalV = document.getElementById('unknownActionsTotalVisible');
        var elMainV = document.getElementById('unknownActionsMainVisible');
        var elWorldV = document.getElementById('unknownActionsWorldVisible');
        var elViewsV = document.getElementById('unknownActionsViewsVisible');
        var elLikesV = document.getElementById('unknownActionsLikesVisible');
        if (elOrdersV) elOrdersV.textContent = String(visible.orders);
        if (elTotalV) elTotalV.textContent = String(visible.total);
        if (elMainV) elMainV.textContent = String(visible.main);
        if (elWorldV) elWorldV.textContent = String(visible.world);
        if (elViewsV) elViewsV.textContent = String(visible.views);
        if (elLikesV) elLikesV.textContent = String(visible.likes);

        var elHiddenLine = document.getElementById('unknownActionsHiddenLine');
        var elOrdersH = document.getElementById('unknownActionsOrdersHidden');
        var elTotalH = document.getElementById('unknownActionsTotalHidden');
        if (elHiddenLine) elHiddenLine.style.display = hiddenOnly ? '' : 'none';
        if (elOrdersH) elOrdersH.textContent = String(hiddenAgg.orders);
        if (elTotalH) elTotalH.textContent = String(hiddenAgg.total);
      } catch (_) {}
    }

    function applyHiddenOrdersToUnknownTable() {
      const hidden = getHiddenOrdersSet();
      const hiddenOnlyCb = document.getElementById('unknownShowHiddenOnly');
      const hiddenOnly = !!(hiddenOnlyCb && hiddenOnlyCb.checked);
      const rows = document.querySelectorAll('tr[data-id]');
      let hiddenCountOnPage = 0;
      rows.forEach(tr => {
        const id = String(tr.getAttribute('data-id') || '');
        const isHidden = !!(id && hidden.has(id));
        if (isHidden) hiddenCountOnPage += 1;
        if (hiddenOnly) {
          tr.style.display = isHidden ? '' : 'none';
        } else {
          tr.style.display = isHidden ? 'none' : '';
        }
      });
      const el = document.getElementById('unknownHiddenCount');
      if (el) el.textContent = String(hiddenCountOnPage);
      updateUnknownActionsSummary();
    }

    function hideSelectedUnknown() {
      const hidden = getHiddenOrdersSet();
      const cbs = document.querySelectorAll('.unknown-hide-cb:checked');
      cbs.forEach(cb => {
        const id = String(cb.getAttribute('data-id') || '');
        if (id) hidden.add(id);
        cb.checked = false;
      });
      const selAll = document.getElementById('unknownSelectAll');
      if (selAll) selAll.checked = false;
      saveHiddenOrdersSet(hidden);
      applyHiddenOrdersToUnknownTable();
    }

    function clearHiddenOrders() {
      try { localStorage.removeItem(HIDDEN_ORDERS_KEY); } catch (_) {}
      try {
        const cb = document.getElementById('unknownShowHiddenOnly');
        if (cb) cb.checked = false;
      } catch (_) {}
      applyHiddenOrdersToUnknownTable();
    }

    async function refreshUnknownPrivatesAndLinks() {
      const statusEl = document.getElementById('unknownRefreshStatus');
      const btn = document.getElementById('unknownRefreshBtn');
      if (btn) { try { btn.disabled = true; btn.style.opacity = '0.6'; } catch(_) {} }
      try {
        if (statusEl) statusEl.textContent = 'Atualizando...';
        const rows = Array.from(document.querySelectorAll('tr[data-id]')).filter(tr => tr && tr.style.display !== 'none');
        const ids = rows.map(tr => String(tr.getAttribute('data-id') || '').trim()).filter(Boolean);
        const res = await fetch('/api/admin/unknown_orderid/refresh', {
          method: 'POST',
          credentials: 'same-origin',
          headers: { 'Content-Type': 'application/json', 'Accept': 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
          body: JSON.stringify({ ids })
        });
        const data = await res.json().catch(() => null);
        if (!res.ok || !data || !data.ok) throw new Error((data && (data.error || data.message)) ? (data.error || data.message) : `HTTP ${res.status}`);
        if (statusEl) statusEl.textContent = `OK: ${data.updated || 0} atualizados`;
        window.location.reload();
      } catch (e) {
        if (statusEl) statusEl.textContent = '';
        alert('Erro ao atualizar: ' + (e && e.message ? e.message : e));
      } finally {
        if (btn) { try { btn.disabled = false; btn.style.opacity = ''; } catch(_) {} }
      }
    }

    (function initUnknownOrderModal() {
      var init = function () {
      try {
        const modal = document.getElementById('unknownOrderModal');
        if (modal) {
          try { modal.style.display = 'none'; } catch (_) {}
          const openId = String(modal.getAttribute('data-open-id') || '').trim();
          if (openId) {
            const dp = String(modal.getAttribute('data-default-provider') || '').trim();
            const lp = String(modal.getAttribute('data-lock-provider') || '').trim();
            openUnknownOrderModal(openId, dp, lp);
          }
        }
      } catch (_) {}

      try {
        document.addEventListener('click', function (ev) {
          const t = ev && ev.target ? ev.target : null;
          if (!t || !t.closest) return;
          const el = t.closest('.unknown-open-modal');
          if (!el) return;
          const id = String(el.getAttribute('data-order-id') || '').trim();
          if (!id) return;
          const dp = String(el.getAttribute('data-default-provider') || '').trim();
          const lp = String(el.getAttribute('data-lock-provider') || '').trim();
          const user = String(el.getAttribute('data-order-user') || '').trim();
          const service = String(el.getAttribute('data-order-service') || '').trim();
          try { ev.preventDefault(); } catch (_) {}
          openUnknownOrderModal(id, dp, lp, { user, service });
        }, true);
      } catch (_) {}

      try {
        const modal = document.getElementById('unknownOrderModal');
        if (modal) {
          modal.addEventListener('click', function (ev) {
            const t = ev && ev.target ? ev.target : null;
            if (t && t.id === 'unknownOrderModal') closeUnknownOrderModal();
          });
        }
      } catch (_) {}

      try {
        document.addEventListener('keydown', function (ev) {
          const key = ev && (ev.key || ev.code) ? String(ev.key || ev.code) : '';
          if (key !== 'Escape') return;
          const modal = document.getElementById('unknownOrderModal');
          if (!modal) return;
          const isOpen = (modal.classList && modal.classList.contains('is-open')) || (String(modal.style.display || '') === 'flex');
          if (isOpen) closeUnknownOrderModal();
        });
      } catch (_) {}

      try {
        const qs = new URLSearchParams(window.location.search || '');
        const id = String(qs.get('openUnknownModal') || '').trim();
        if (id) {
          const dp = String(qs.get('defaultProvider') || '').trim();
          const lp = String(qs.get('lockProvider') || '').trim();
          openUnknownOrderModal(id, dp, lp);
          try {
            qs.delete('openUnknownModal');
            qs.delete('defaultProvider');
            qs.delete('lockProvider');
            const base = window.location.pathname || '/painel';
            const newQs = qs.toString();
            const newUrl = newQs ? (base + '?' + newQs) : base;
            window.history.replaceState(null, '', newUrl);
          } catch (_) {}
        }
      } catch (_) {}

      const selAll = document.getElementById('unknownSelectAll');
      if (selAll) {
        selAll.addEventListener('change', function () {
          const checked = !!selAll.checked;
          const cbs = document.querySelectorAll('.unknown-hide-cb');
          cbs.forEach(cb => {
            const tr = cb.closest('tr[data-id]');
            const isVisible = !tr || tr.style.display !== 'none';
            if (isVisible) cb.checked = checked;
          });
        });
      }
      try {
        const cb = document.getElementById('unknownShowHiddenOnly');
        if (cb && !cb.__boundHiddenOnly) {
          cb.__boundHiddenOnly = true;
          cb.addEventListener('change', function(){ applyHiddenOrdersToUnknownTable(); });
        }
      } catch (_) {}
      applyHiddenOrdersToUnknownTable();
      };
      try {
        if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', init);
        else init();
      } catch (_) { try { init(); } catch(_) {} }
    })();
  </script>
  <% } %>
</body>
</html>
