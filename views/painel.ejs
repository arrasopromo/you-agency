              <script type="application/json" id="ltvCustomersData"><%- JSON.stringify(ltvDashRows) %></script>
              <script>
                (function(){
                  function readJson(id, fallback) {
                    try {
                      var el = document.getElementById(id);
                      if (!el) return fallback;
                      var raw = String(el.textContent || '').trim();
                      if (!raw) return fallback;
                      return JSON.parse(raw);
                    } catch (_) {
                      return fallback;
                    }
                  }
                  function fmtMoney(n) {
                    var x = Number(n || 0);
                    if (!isFinite(x)) x = 0;
                    return 'R$ ' + x.toFixed(2).replace('.', ',');
                  }
                  function safeStr(v) { return String(v == null ? '' : v); }
                  var all = readJson('ltvCustomersData', []);
                  var modal = document.getElementById('ltvCustomersModal');
                  var titleEl = document.getElementById('ltvCustomersModalTitle');
                  var closeBtn = document.getElementById('ltvCustomersModalClose');
                  var tbody = document.getElementById('ltvCustomersTbody');
                  var searchEl = document.getElementById('ltvCustomersSearch');
                  var countEl = document.getElementById('ltvCustomersCount');
                  var cardAll = document.getElementById('ltvCardAllCustomers');
                  var cardRepeat = document.getElementById('ltvCardRepeatCustomers');
                  if (!modal || !tbody) return;
                  var mode = 'all';
                  function open(newMode) {
                    mode = newMode || 'all';
                    if (titleEl) titleEl.textContent = mode === 'repeat' ? 'Clientes recorrentes (2+)' : 'Clientes únicos';
                    if (searchEl) searchEl.value = '';
                    modal.style.display = 'flex';
                    render();
                    if (searchEl) searchEl.focus();
                  }
                  function close() { modal.style.display = 'none'; }
                  function matchesFilter(row, q) {
                    if (!q) return true;
                    var s = (safeStr(row.username) + ' ' + safeStr(row.phone) + ' ' + safeStr(row.email) + ' ' + safeStr(row.label)).toLowerCase();
                    return s.indexOf(q) >= 0;
                  }
                  function render() {
                    var q = searchEl ? String(searchEl.value || '').trim().toLowerCase() : '';
                    var rows = Array.isArray(all) ? all.slice() : [];
                    if (mode === 'repeat') rows = rows.filter(function(r){ return Number(r && r.orders ? r.orders : 0) > 1; });
                    rows = rows.filter(function(r){ return matchesFilter(r, q); });
                    if (countEl) countEl.textContent = rows.length + ' clientes';
                    tbody.innerHTML = '';
                    if (!rows.length) {
                      var tr0 = document.createElement('tr');
                      var td0 = document.createElement('td');
                      td0.colSpan = 5;
                      td0.style.padding = '10px 6px';
                      td0.style.color = '#6b7280';
                      td0.textContent = 'Sem dados';
                      tr0.appendChild(td0);
                      tbody.appendChild(tr0);
                      return;
                    }
                    for (var i = 0; i < rows.length; i++) {
                      var r = rows[i] || {};
                      var tr = document.createElement('tr');
                      var tdUser = document.createElement('td');
                      tdUser.style.padding = '8px 6px';
                      tdUser.style.borderBottom = '1px solid #fafafa';
                      tdUser.textContent = safeStr(r.label || r.username || '-');
                      var tdPhone = document.createElement('td');
                      tdPhone.style.padding = '8px 6px';
                      tdPhone.style.borderBottom = '1px solid #fafafa';
                      tdPhone.textContent = safeStr(r.phone || '-');
                      var tdEmail = document.createElement('td');
                      tdEmail.style.padding = '8px 6px';
                      tdEmail.style.borderBottom = '1px solid #fafafa';
                      tdEmail.textContent = safeStr(r.email || '-');
                      var tdOrders = document.createElement('td');
                      tdOrders.style.padding = '8px 6px';
                      tdOrders.style.borderBottom = '1px solid #fafafa';
                      tdOrders.style.textAlign = 'right';
                      tdOrders.textContent = String(Number(r.orders || 0));
                      var tdSpend = document.createElement('td');
                      tdSpend.style.padding = '8px 6px';
                      tdSpend.style.borderBottom = '1px solid #fafafa';
                      tdSpend.style.textAlign = 'right';
                      tdSpend.textContent = fmtMoney(r.spend || 0);
                      tr.appendChild(tdUser);
                      tr.appendChild(tdPhone);
                      tr.appendChild(tdEmail);
                      tr.appendChild(tdOrders);
                      tr.appendChild(tdSpend);
                      tbody.appendChild(tr);
                    }
                  }
                  if (cardAll) cardAll.addEventListener('click', function(){ open('all'); });
                  if (cardRepeat) cardRepeat.addEventListener('click', function(){ open('repeat'); });
                  if (closeBtn) closeBtn.addEventListener('click', close);
                  modal.addEventListener('click', function(e){
                    if (e && e.target === modal) close();
                  });
                  if (searchEl) searchEl.addEventListener('input', render);
                })();
              </script>
            </div>
          </div>
          <% } %>
        <% } %>

        <% if (!isCouponsView && !isFollowersMgmtView && !isWhatsappSalesView && !isLtvView && view === 'dashboard') { %>
        <div style="border:1px solid #e5e7eb; border-radius:10px; padding:14px; background:#fff; margin-top: 18px;">
          <div style="display:flex; align-items:center; justify-content:space-between; gap:10px; flex-wrap: wrap;">
            <strong style="font-size:1.05rem; color:#111827;">Geolocalização de Acessos e Perfis Validados</strong>
            <span style="font-size:0.9rem; color:#6b7280;">Dados de acessos (page_views) e pedidos (checkout_orders)</span>
          </div>
          <div style="display:grid; grid-template-columns: 1fr 1fr; gap:16px; margin-top:12px;">
            <div style="min-width:0;">
              <div style="border:1px solid #e5e7eb; border-radius:8px; overflow:hidden;">
                <div style="padding:10px; font-weight:700; background:#fafafa; border-bottom:1px solid #e5e7eb;">Top Cidades</div>
                <div style="max-height:420px; overflow:auto;">
                  <table style="width:100%; border-collapse:collapse;">
                    <thead>
                      <tr>
                        <th style="text-align:left; padding:8px; border-bottom:1px solid #e5e7eb; background:#f9fafb;">Cidade</th>
                        <th style="text-align:left; padding:8px; border-bottom:1px solid #e5e7eb; background:#f9fafb;">Região</th>
                        <th style="text-align:left; padding:8px; border-bottom:1px solid #e5e7eb; background:#f9fafb;">País</th>
                        <th style="text-align:right; padding:8px; border-bottom:1px solid #e5e7eb; background:#f9fafb;">Visitas</th>
                      </tr>
                    </thead>
                    <tbody id="geoCitiesTbody">
                      <tr><td colspan="4" style="padding:10px; color:#777;">Carregando…</td></tr>
                    </tbody>
                  </table>
                </div>
              </div>
            </div>
            <div style="min-width:0;">
              <div style="border:1px solid #e5e7eb; border-radius:8px; overflow:hidden;">
                <div style="padding:10px; font-weight:700; background:#fafafa; border-bottom:1px solid #e5e7eb;">Mapa</div>
                <div id="geoMap" style="height:420px;"></div>
              </div>
            </div>
          </div>
        </div>
        <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/q19p1Z0wZyy3R0Xv0=" crossorigin="anonymous">
        <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin="anonymous"></script>
        <script>
          (function(){
            var geoMapInstance = null;
            function q(id){ return document.getElementById(id); }
            function renderGeoTable(rows){
              var tb = q('geoCitiesTbody');
              if (!tb) return;
              if (!rows || !rows.length) {
                tb.innerHTML = '<tr><td colspan="4" style="padding:10px; color:#777;">Sem dados</td></tr>';
                return;
              }
              var html = '';
              rows.forEach(function(r){
                html += '<tr>'
                  + '<td style="padding:8px; border-bottom:1px solid #f1f5f9;">'+ (r.city || '-') +'</td>'
                  + '<td style="padding:8px; border-bottom:1px solid #f1f5f9;">'+ (r.region || '-') +'</td>'
                  + '<td style="padding:8px; border-bottom:1px solid #f1f5f9;">'+ (r.country || '-') +'</td>'
                  + '<td style="padding:8px; border-bottom:1px solid #f1f5f9; text-align:right;">'+ (r.count || 0) +'</td>'
                  + '</tr>';
              });
              tb.innerHTML = html;
            }
            function initMap(pointsVisits, pointsProfiles){
              var el = q('geoMap');
              if (!el || typeof L === 'undefined') return;
              try {
                if (geoMapInstance && typeof geoMapInstance.remove === 'function') geoMapInstance.remove();
              } catch (_) {}
              geoMapInstance = null;
              try { el.innerHTML = ''; } catch (_) {}
              var map = L.map(el).setView([-15.78, -47.93], 4);
              geoMapInstance = map;
              L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
                attribution: '&copy; OpenStreetMap',
                maxZoom: 18
              }).addTo(map);
              var bounds = [];
              (pointsVisits || []).forEach(function(p){
                if (typeof p.lat === 'number' && typeof p.lon === 'number') {
                  var m = L.circleMarker([p.lat, p.lon], { radius: 5, color: '#2563eb', fillColor: '#3b82f6', fillOpacity: 0.7, weight: 1 });
                  m.bindPopup('<strong>Visitas</strong><br>'+ (p.city||'-') +', '+ (p.region||'-') +' - '+ (p.country||'-') +'<br>Qtd: '+ (p.count||0));
                  m.addTo(map);
                  bounds.push([p.lat, p.lon]);
                }
              });
              (pointsProfiles || []).forEach(function(p){
                if (typeof p.lat === 'number' && typeof p.lon === 'number') {
                  var m = L.circleMarker([p.lat, p.lon], { radius: 6, color: '#7c3aed', fillColor: '#a78bfa', fillOpacity: 0.8, weight: 1.2 });
                  m.bindPopup('<strong>Perfis Validados</strong><br>'+ (p.city||'-') +', '+ (p.region||'-') +' - '+ (p.country||'-') +'<br>Qtd: '+ (p.count||0));
                  m.addTo(map);
                  bounds.push([p.lat, p.lon]);
                }
              });
              if (bounds.length) {
                try { map.fitBounds(bounds, { padding: [20,20] }); } catch(_) {}
              }
              try { setTimeout(function(){ try { map.invalidateSize(); } catch (_) {} }, 250); } catch (_) {}
            }
            fetch('/api/geo/aggregate')
              .then(function(r){ return r.json(); })
              .then(function(data){
                if (!data || data.ok !== true) throw new Error('sem dados');
                var visits = Array.isArray(data.visits) ? data.visits : [];
                var profiles = Array.isArray(data.profiles) ? data.profiles : [];
                var topCities = visits.slice().sort(function(a,b){ return (b.count||0)-(a.count||0); }).slice(0, 100);
                renderGeoTable(topCities);
                initMap(visits, profiles);
              })
              .catch(function(){
                renderGeoTable([]);
                initMap([], []);
              });
          })();
        </script>
        <% } %>
      </div>

