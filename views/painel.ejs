          if (filters && filters.startDate) parts.push(`startDate=${encodeURIComponent(String(filters.startDate))}`);
          if (filters && filters.endDate) parts.push(`endDate=${encodeURIComponent(String(filters.endDate))}`);
          if (filters && filters.dateField && String(filters.dateField) !== 'purchase') parts.push(`dateField=${encodeURIComponent(String(filters.dateField))}`);
          if (filters && filters.tipo) parts.push(`tipo=${encodeURIComponent(String(filters.tipo))}`);
          if (filters && typeof filters.minPct === 'number') parts.push(`minPct=${encodeURIComponent(String(filters.minPct))}`);
          if (filters && typeof filters.maxPct === 'number') parts.push(`maxPct=${encodeURIComponent(String(filters.maxPct))}`);
          if (filters && filters.sortBy) parts.push(`sortBy=${encodeURIComponent(String(filters.sortBy))}`);
          if (filters && filters.sortDir) parts.push(`sortDir=${encodeURIComponent(String(filters.sortDir))}`);
          parts.push(`page=${encodeURIComponent(String(targetPage || 1))}`);
          return '/painel/gerenciamento-seguidores' + (parts.length ? ('?' + parts.join('&')) : '');
        };
        const curPage = (pagination && pagination.page) ? pagination.page : 1;
        const totalPages = (pagination && pagination.totalPages) ? pagination.totalPages : 1;
      %>
      <div style="display:flex; justify-content:space-between; align-items:center; margin-top: 12px; flex-wrap: wrap; gap: 10px;">
        <div style="font-size:0.9rem; color:#555;">Página <%= curPage %> de <%= totalPages %></div>
        <div style="display:flex; gap:8px; align-items:center;">
          <a href="<%= buildFollowersUrl(Math.max(1, curPage - 1)) %>" class="followers-pager-link <%= curPage <= 1 ? 'followers-pager-link--disabled' : '' %>">Anterior</a>
          <a href="<%= buildFollowersUrl(Math.min(totalPages, curPage + 1)) %>" class="followers-pager-link <%= curPage >= totalPages ? 'followers-pager-link--disabled' : '' %>">Próxima</a>
        </div>
      </div>

    <% } else if (isCouponsView) { %>
      <div id="cupons" style="border:1px solid #ddd; border-radius:8px; padding:16px; background:#fafafa; margin-top: 16px;">
        <h2 style="margin:0 0 8px; font-size:1rem;">Cupons</h2>
        <div style="color:#666; font-size:0.9rem; margin-bottom: 10px;">Para editar um cupom já criado, use o botão “Editar” na lista (ou clique na linha), ajuste os campos e clique em “Salvar”.</div>
        <div style="display:grid; grid-template-columns: 1fr; gap: 12px;">
          <div style="display:grid; grid-template-columns: 1fr 90px; gap: 8px;">
            <input type="hidden" id="couponIdInput" value="">
            <input type="text" id="couponCodeInput" placeholder="CÓDIGO" style="padding:6px; border:1px solid #ccc; border-radius:4px; text-transform:uppercase;">
            <input type="number" id="couponDiscountInput" placeholder="%" style="padding:6px; border:1px solid #ccc; border-radius:4px;" min="1" max="100">
          </div>
          <div style="display:grid; grid-template-columns: 1fr 1fr; gap: 8px;">
            <input type="number" id="couponMaxUsesTotalInput" placeholder="Limite total (opcional)" style="padding:6px; border:1px solid #ccc; border-radius:4px;" min="1">
            <input type="number" id="couponMaxUsesPerProfileInput" placeholder="Limite por perfil (opcional)" style="padding:6px; border:1px solid #ccc; border-radius:4px;" min="1">
          </div>
          <div style="display:grid; grid-template-columns: 1fr 1fr; gap: 8px;">
            <input type="datetime-local" id="couponValidFromInput" style="padding:6px; border:1px solid #ccc; border-radius:4px;">
            <input type="datetime-local" id="couponValidToInput" style="padding:6px; border:1px solid #ccc; border-radius:4px;">
          </div>
          <label style="display:flex; align-items:center; gap:8px;">
            <input type="checkbox" id="couponIsActiveInput" checked>
            <span>Ativo</span>
          </label>
          <div style="display:flex; gap:8px; justify-content:flex-end;">
            <button type="button" onclick="clearCouponForm()" style="padding:6px 12px; background:#6c757d; color:#fff; border:none; border-radius:4px; cursor:pointer;">Limpar</button>
            <button type="button" onclick="saveCoupon()" style="padding:6px 12px; background:#28a745; color:#fff; border:none; border-radius:4px; cursor:pointer;">Salvar</button>
          </div>
        </div>

        <div style="margin-top: 14px; border-top: 1px solid #eaeaea; padding-top: 12px;">
          <div style="font-size: 0.9rem; font-weight: 600; margin-bottom: 8px;">Lista</div>
          <div style="max-height: 520px; overflow-y: auto; border: 1px solid #eee; border-radius: 6px; background: #fff;">
            <div class="panel-table-scroll">
            <table style="width:100%; border-collapse: collapse; min-width: 820px;">
              <thead>
                <tr>
                  <th style="text-align:left; padding:8px; border-bottom:1px solid #eee;">Código</th>
                  <th style="text-align:right; padding:8px; border-bottom:1px solid #eee;">%</th>
                  <th style="text-align:center; padding:8px; border-bottom:1px solid #eee;">Ativo</th>
                  <th style="text-align:right; padding:8px; border-bottom:1px solid #eee;">Usos</th>
                  <th style="text-align:right; padding:8px; border-bottom:1px solid #eee;">Limite</th>
                  <th style="text-align:right; padding:8px; border-bottom:1px solid #eee;">Por perfil</th>
                  <th style="text-align:left; padding:8px; border-bottom:1px solid #eee;">Validade</th>
                  <th style="text-align:center; padding:8px; border-bottom:1px solid #eee;">Ação</th>
                </tr>
              </thead>
              <tbody id="couponsListBody">
                <tr><td colspan="8" style="padding:10px; color:#777; text-align:center;">Carregando…</td></tr>
              </tbody>
            </table>
            </div>
          </div>
        </div>

        <script>
          function toLocalDateTimeInputValue(d) {
            if (!d) return '';
            const dt = new Date(d);
            if (Number.isNaN(dt.getTime())) return '';
            const pad = (n) => String(n).padStart(2, '0');
            const y = dt.getFullYear();
            const m = pad(dt.getMonth() + 1);
            const day = pad(dt.getDate());
            const hh = pad(dt.getHours());
            const mm = pad(dt.getMinutes());
            return `${y}-${m}-${day}T${hh}:${mm}`;
          }

          function getCouponFormPayload() {
            const id = String(document.getElementById('couponIdInput').value || '').trim();
            const code = String(document.getElementById('couponCodeInput').value || '').trim().toUpperCase();
            const discountPercentage = Number(document.getElementById('couponDiscountInput').value || 0) || 0;
            const maxUsesTotalRaw = String(document.getElementById('couponMaxUsesTotalInput').value || '').trim();
            const maxUsesPerProfileRaw = String(document.getElementById('couponMaxUsesPerProfileInput').value || '').trim();
            const validFromRaw = String(document.getElementById('couponValidFromInput').value || '').trim();
            const validToRaw = String(document.getElementById('couponValidToInput').value || '').trim();
            const isActive = !!document.getElementById('couponIsActiveInput').checked;
            const maxUsesTotal = maxUsesTotalRaw ? (Number(maxUsesTotalRaw) || null) : null;
            const maxUsesPerProfile = maxUsesPerProfileRaw ? (Number(maxUsesPerProfileRaw) || null) : null;
            const validFrom = validFromRaw ? new Date(validFromRaw).toISOString() : null;
            const validTo = validToRaw ? new Date(validToRaw).toISOString() : null;
            return { id, code, discountPercentage, maxUsesTotal, maxUsesPerProfile, validFrom, validTo, isActive };
          }

          function clearCouponForm() {
            document.getElementById('couponIdInput').value = '';
            document.getElementById('couponCodeInput').value = '';
            document.getElementById('couponDiscountInput').value = '';
            document.getElementById('couponMaxUsesTotalInput').value = '';
            document.getElementById('couponMaxUsesPerProfileInput').value = '';
            document.getElementById('couponValidFromInput').value = '';
            document.getElementById('couponValidToInput').value = '';
            document.getElementById('couponIsActiveInput').checked = true;
          }

          function fillCouponForm(c) {
            document.getElementById('couponIdInput').value = c && c._id ? String(c._id) : '';
            document.getElementById('couponCodeInput').value = c && c.code ? String(c.code) : '';
            document.getElementById('couponDiscountInput').value = (c && c.discountPercentage != null) ? String(c.discountPercentage) : '';
            document.getElementById('couponMaxUsesTotalInput').value = (c && c.maxUsesTotal != null) ? String(c.maxUsesTotal) : '';
            document.getElementById('couponMaxUsesPerProfileInput').value = (c && c.maxUsesPerProfile != null) ? String(c.maxUsesPerProfile) : '';
            document.getElementById('couponValidFromInput').value = toLocalDateTimeInputValue(c && c.validFrom ? c.validFrom : '');
            document.getElementById('couponValidToInput').value = toLocalDateTimeInputValue(c && c.validTo ? c.validTo : '');
            document.getElementById('couponIsActiveInput').checked = !(c && c.isActive === false);
            try { document.getElementById('couponCodeInput').scrollIntoView({ behavior: 'smooth', block: 'center' }); } catch (_) {}
          }

          function formatValidity(c) {
            const from = c && c.validFrom ? new Date(c.validFrom) : null;
            const to = c && c.validTo ? new Date(c.validTo) : null;
            const fmt = (d) => {
              if (!d || Number.isNaN(d.getTime())) return '';
              const pad = (n) => String(n).padStart(2,'0');
              return `${pad(d.getDate())}/${pad(d.getMonth()+1)} ${pad(d.getHours())}:${pad(d.getMinutes())}`;
            };
            const a = fmt(from);
            const b = fmt(to);
            if (a && b) return `${a} → ${b}`;
            return a || b || '-';
          }

          async function loadCoupons() {
            const tbody = document.getElementById('couponsListBody');
            try {
              const res = await fetch('/api/admin/coupons');
              const data = await res.json();
              if (!data || !data.success) throw new Error(data && (data.error || data.message) ? (data.error || data.message) : 'Falha ao carregar cupons');
              renderCoupons(Array.isArray(data.coupons) ? data.coupons : []);
            } catch (e) {
              if (tbody) tbody.innerHTML = '<tr><td colspan="8" style="padding:10px; color:#dc3545; text-align:center;">Erro ao carregar cupons</td></tr>';
            }
          }

          function renderCoupons(list) {
            const tbody = document.getElementById('couponsListBody');
            if (!tbody) return;
            tbody.innerHTML = '';
            if (!list.length) {
              tbody.innerHTML = '<tr><td colspan="8" style="padding:10px; color:#777; text-align:center;">Nenhum cupom</td></tr>';
              return;
            }
            list.forEach(c => {
              const tr = document.createElement('tr');
              tr.style.cursor = 'pointer';
              tr.onclick = () => fillCouponForm(c);
              const usedCount = (typeof c.usedCount === 'number') ? c.usedCount : 0;
              const maxTotal = (c.maxUsesTotal != null) ? String(c.maxUsesTotal) : '-';
              const maxPer = (c.maxUsesPerProfile != null) ? String(c.maxUsesPerProfile) : '-';
              const isActive = !(c && c.isActive === false);
              tr.innerHTML = `
                <td style="padding:8px; border-bottom:1px solid #f2f2f2;"><strong>${String(c.code || '')}</strong></td>
                <td style="padding:8px; border-bottom:1px solid #f2f2f2; text-align:right;">${String(c.discountPercentage || 0)}%</td>
                <td style="padding:8px; border-bottom:1px solid #f2f2f2; text-align:center;">
                  <input type="checkbox" data-role="active" ${isActive ? 'checked' : ''} />
                </td>
                <td style="padding:8px; border-bottom:1px solid #f2f2f2; text-align:right;">${usedCount}</td>
                <td style="padding:8px; border-bottom:1px solid #f2f2f2; text-align:right;">${maxTotal}</td>
                <td style="padding:8px; border-bottom:1px solid #f2f2f2; text-align:right;">${maxPer}</td>
                <td style="padding:8px; border-bottom:1px solid #f2f2f2;">${formatValidity(c)}</td>
                <td style="padding:8px; border-bottom:1px solid #f2f2f2; text-align:center;">
                  <button type="button" data-role="edit" style="padding:4px 8px; background:#0d6efd; color:#fff; border:none; border-radius:4px; cursor:pointer; margin-right:6px;">Editar</button>
                  <button type="button" data-role="del" style="padding:4px 8px; background:#dc3545; color:#fff; border:none; border-radius:4px; cursor:pointer;">Remover</button>
                </td>
              `;
              const editBtn = tr.querySelector('button[data-role="edit"]');
              if (editBtn) {
                editBtn.onclick = (ev) => { ev.stopPropagation(); fillCouponForm(c); };
              }
              const delBtn = tr.querySelector('button[data-role="del"]');
              if (delBtn) {
                delBtn.onclick = (ev) => { ev.stopPropagation(); deleteCoupon(String(c._id || '')); };
              }
              const activeCb = tr.querySelector('input[data-role="active"]');
              if (activeCb) {
                activeCb.onmousedown = (ev) => { ev.stopPropagation(); };
                activeCb.onclick = (ev) => { ev.stopPropagation(); };
                activeCb.onchange = async (ev) => {
                  ev.stopPropagation();
                  try {
                    const id = String(c._id || '').trim();
                    if (!id) return;
                    const res = await fetch('/api/admin/coupons/' + encodeURIComponent(id), {
                      method: 'PUT',
                      headers: { 'Content-Type': 'application/json' },
                      body: JSON.stringify({ isActive: !!activeCb.checked })
                    });
                    const data = await res.json();
                    if (!data || !data.success) throw new Error(data && (data.error || data.message) ? (data.error || data.message) : 'Falha ao atualizar cupom');
                    loadCoupons();
                  } catch (e) {
                    activeCb.checked = !activeCb.checked;
                    alert('Erro ao atualizar cupom: ' + (e && e.message ? e.message : e));
                  }
                };
              }
              tbody.appendChild(tr);
            });
          }

          async function saveCoupon() {
            const payload = getCouponFormPayload();
            if (!payload.code || !payload.discountPercentage) {
              alert('Preencha código e porcentagem.');
              return;
            }
            try {
              const isEdit = !!payload.id;
              const url = isEdit ? ('/api/admin/coupons/' + encodeURIComponent(payload.id)) : '/api/admin/coupons';
              const method = isEdit ? 'PUT' : 'POST';
              const res = await fetch(url, { method, headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(payload) });
              const data = await res.json();
              if (!data || !data.success) throw new Error(data && (data.error || data.message) ? (data.error || data.message) : 'Falha ao salvar cupom');
              clearCouponForm();
              loadCoupons();
            } catch (e) {
              alert('Erro ao salvar cupom: ' + (e && e.message ? e.message : e));
            }
          }

          async function deleteCoupon(id) {
            if (!id) return;
            if (!confirm('Remover este cupom?')) return;
            try {
              const res = await fetch('/api/admin/coupons/' + encodeURIComponent(id), { method: 'DELETE' });
              const data = await res.json();
              if (!data || !data.success) throw new Error(data && (data.error || data.message) ? (data.error || data.message) : 'Falha ao remover cupom');
              loadCoupons();
            } catch (e) {
              alert('Erro ao remover cupom: ' + (e && e.message ? e.message : e));
            }
          }

          loadCoupons();
        </script>
      </div>
    <% } else { %>
    <% if (isUnknownOrderIdView) { %>
      <div class="summary-grid">
        <div class="summary-card">
          <div class="summary-label">Pedidos com OrderID Unknown</div>
          <div class="summary-value"><%= totalUnknown || 0 %></div>
        </div>
        <div class="summary-card" id="unknownActionsCard">
          <div class="summary-label">Pedidos com ações disponíveis (visíveis)</div>
          <div class="summary-value" id="unknownActionsOrdersVisible">0</div>
          <div class="summary-sub"><span id="unknownActionsTotalVisible">0</span> ações no total</div>
          <div class="summary-sub" style="margin-top:6px;">
            Main: <span id="unknownActionsMainVisible">0</span> · Comentários: <span id="unknownActionsWorldVisible">0</span> · Views Bump: <span id="unknownActionsViewsVisible">0</span> · Curtidas Bump: <span id="unknownActionsLikesVisible">0</span>
          </div>
          <div class="summary-sub" id="unknownActionsHiddenLine" style="margin-top:6px; display:none;">
            Ocultos: <span id="unknownActionsOrdersHidden">0</span> pedidos · <span id="unknownActionsTotalHidden">0</span> ações
          </div>
        </div>
      </div>
    <% } else if (!isLtvView && !isWhatsappSalesView && !isFollowersMgmtView && !isRefil2View) { %>
      <div class="summary-grid summary-grid-dashboard">
        <div class="summary-card">
          <div class="summary-label">Total de Vendas</div>
          <div class="summary-value">R$ <%= (typeof revenueShown !== 'undefined' ? Number(revenueShown || 0) : Number(totalRevenue || 0)).toFixed(2).replace('.', ',') %></div>
        </div>
        <div class="summary-card">
          <div class="summary-label">Ticket Médio</div>
          <div class="summary-value">R$ <%= (typeof avgTicket !== 'undefined' ? Number(avgTicket || 0) : 0).toFixed(2).replace('.', ',') %></div>
        </div>
        <div class="summary-card">
          <div class="summary-label">Custo Total no Período</div>
          <div class="summary-value">R$ <%= totalCost.toFixed(2).replace('.', ',') %></div>
        </div>
        <div class="summary-card">
          <div class="summary-label">% custo / vendas (período)</div>
          <div class="summary-value"><%= (typeof costOverRevenuePct !== 'undefined' ? Number(costOverRevenuePct || 0) : 0).toFixed(1).replace('.', ',') %>%</div>
        </div>
        <div class="summary-card">
          <div class="summary-label">Perfis validados hoje</div>
          <div class="summary-value"><%= typeof validatedProfilesToday !== 'undefined' ? validatedProfilesToday : 0 %></div>
        </div>
        <div class="summary-card">
          <div class="summary-label">Pedidos pagos hoje</div>
          <div class="summary-value"><%= typeof paidOrdersToday !== 'undefined' ? paidOrdersToday : 0 %></div>
        </div>
        <div class="summary-card">
          <div class="summary-label">Perfis validados no período</div>
          <div class="summary-value"><%= typeof validatedProfilesPeriod !== 'undefined' ? validatedProfilesPeriod : 0 %></div>
        </div>
        <div class="summary-card">
          <div class="summary-label">Pedidos pagos no período</div>
          <div class="summary-value"><%= totalTransactions %></div>
        </div>
        <div class="summary-card">
          <div class="summary-label">% pagos/validados (hoje)</div>
          <div class="summary-value"><%= (typeof paidOverValidatedTodayPct !== 'undefined' ? Number(paidOverValidatedTodayPct || 0) : 0).toFixed(1).replace('.', ',') %>%</div>
        </div>
        <div class="summary-card">
          <div class="summary-label">% pagos/validados (período)</div>
          <div class="summary-value"><%= (typeof paidOverValidatedPeriodPct !== 'undefined' ? Number(paidOverValidatedPeriodPct || 0) : 0).toFixed(1).replace('.', ',') %>%</div>
        </div>
        <div class="summary-card">
          <div class="summary-label">Vendas sem orderbump</div>
          <div class="summary-value">R$ <%= (typeof revenueWithoutBumps !== 'undefined' ? Number(revenueWithoutBumps || 0) : 0).toFixed(2).replace('.', ',') %></div>
          <div style="margin-top:8px;">
            <a href="<%= (typeof toggleIgnoreBumpRevenueUrl !== 'undefined' && toggleIgnoreBumpRevenueUrl) ? toggleIgnoreBumpRevenueUrl : '/painel' %>" style="display:inline-block; padding:6px 10px; background:#0d6efd; color:#fff; border-radius:6px; text-decoration:none; font-size:0.85rem;">
              <%= (typeof ignoreBumpRevenue !== 'undefined' && ignoreBumpRevenue) ? 'Considerar venda de orderbump' : 'Retirar venda de orderbump' %>
            </a>
          </div>
        </div>
      </div>
      <% if (view === 'dashboard') { %>
      <div id="dashboardRealtimeWrap" style="margin-top: 14px; border:1px solid #e5e7eb; border-radius: 10px; padding: 14px; background: #fff; width:100%; box-sizing:border-box;">
        <div style="display:flex; justify-content:space-between; align-items:center; gap:10px; flex-wrap: wrap;">
          <strong style="font-size: 1rem; color:#111827;">Tempo real</strong>
          <div style="font-size:0.85rem; color:#6b7280;">Atualiza automaticamente</div>
        </div>
        <div class="summary-grid" style="margin-top: 12px;">
          <div class="summary-card">
            <div class="summary-label">Online agora</div>
            <div class="summary-value" id="dashboardOnlineNowCount"><%= (typeof onlineNow !== 'undefined' ? Number(onlineNow || 0) : 0) %></div>
          </div>
          <div class="summary-card">
            <div class="summary-label">Acessos /servicos-instagram (período)</div>
            <div class="summary-value"><%= (typeof servicePageViews !== 'undefined' && servicePageViews ? (servicePageViews.instagram || 0) : 0) %></div>
          </div>
          <div class="summary-card">
            <div class="summary-label">Acessos /servicos-curtidas (período)</div>
            <div class="summary-value"><%= (typeof servicePageViews !== 'undefined' && servicePageViews ? (servicePageViews.curtidas || 0) : 0) %></div>
          </div>
          <div class="summary-card">
            <div class="summary-label">Acessos /servicos-visualizacoes (período)</div>
            <div class="summary-value"><%= (typeof servicePageViews !== 'undefined' && servicePageViews ? (servicePageViews.visualizacoes || 0) : 0) %></div>
          </div>
        </div>
        <script>
          (function(){
            try {
              var key = 'oppus_client_id';
              var cid = '';
              try { cid = String(localStorage.getItem(key) || ''); } catch (_) {}
              if (!cid) {
                cid = (typeof crypto !== 'undefined' && crypto && typeof crypto.randomUUID === 'function')
                  ? crypto.randomUUID()
                  : (Date.now().toString(36) + Math.random().toString(36).slice(2));
                try { localStorage.setItem(key, cid); } catch (_) {}
              }
              var ping = function() {
                try {
                  var payload = JSON.stringify({ clientId: cid, path: (location && location.pathname) ? location.pathname : '' });
                  if (navigator && typeof navigator.sendBeacon === 'function') {
                    navigator.sendBeacon('/api/online/ping', new Blob([payload], { type: 'application/json' }));
                    return;
                  }
                  fetch('/api/online/ping', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: payload, keepalive: true }).catch(function(){});
                } catch (_) {}
              };
              ping();
              setInterval(ping, 15000);
              document.addEventListener('visibilitychange', function(){ if (!document.hidden) ping(); });

              var el = document.getElementById('dashboardOnlineNowCount');
              if (!el) return;
              var tick = function() {
                fetch('/api/online/stats', { headers: { 'Accept': 'application/json' } })
                  .then(function(r){ return r.json(); })
                  .then(function(d){
                    var v = (d && typeof d.online !== 'undefined') ? Number(d.online || 0) : 0;
                    el.textContent = String(v);
                  })
                  .catch(function(){});
              };
              tick();
              setInterval(tick, 10000);
            } catch (_) {}
          })();
        </script>
      </div>

      <div id="timelineChartsWrap" style="margin-top: 14px; border:1px solid #e5e7eb; border-radius: 10px; padding: 14px; background: #fff; width:100%; box-sizing:border-box;">
        <div style="display:flex; justify-content:space-between; align-items:center; gap:10px; flex-wrap: wrap;">
          <strong style="font-size: 1rem; color:#111827;">Evolução diária</strong>
          <div style="font-size:0.85rem; color:#6b7280;">Base: pedidos pagos (período)</div>
        </div>
        <div style="display:flex; gap:16px; flex-wrap:wrap; margin-top: 12px;">
          <div style="flex:1 1 420px; min-width: 320px;">
            <div style="font-weight:700; margin-bottom:8px; color:#111827;">Ticket médio (R$)</div>
            <canvas id="avgTicketTimelineChart" height="140"></canvas>
          </div>
          <div style="flex:1 1 420px; min-width: 320px;">
            <div style="font-weight:700; margin-bottom:8px; color:#111827;">Faturamento (R$)</div>
            <canvas id="salesRevenueTimelineChart" height="140"></canvas>
          </div>
          <div style="flex:1 1 420px; min-width: 320px;">
            <div style="font-weight:700; margin-bottom:8px; color:#111827;">% pagos / validados</div>
            <canvas id="paidValidatedPctTimelineChart" height="140"></canvas>
          </div>
        </div>
        <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
        <script type="application/json" id="timelineSeriesData"><%- JSON.stringify((typeof timelineSeries !== 'undefined' && timelineSeries) ? timelineSeries : { labels: [], dailyOrders: [], dailyRevenue: [], dailyAvgTicket: [] }) %></script>
        <script type="application/json" id="paidValidatedSeriesData"><%- JSON.stringify((typeof paidValidatedSeries !== 'undefined' && paidValidatedSeries) ? paidValidatedSeries : { labels: [], dailyPct: [], dailyPaid: [], dailyValidated: [] }) %></script>
        <script>
          (function(){
            try {
              if (typeof Chart === 'undefined') return;
              var rawEl = document.getElementById('timelineSeriesData');
              var raw = rawEl ? String(rawEl.textContent || '').trim() : '';
              var data = raw ? JSON.parse(raw) : { labels: [], dailyOrders: [], dailyRevenue: [], dailyAvgTicket: [] };
              var labels = Array.isArray(data.labels) ? data.labels : [];
              var fmt = function(k){
                try {
                  var parts = String(k || '').split('-');
                  if (parts.length !== 3) return String(k || '');
                  return parts[2] + '/' + parts[1];
                } catch (_) { return String(k || ''); }
              };
              var labelShort = labels.map(fmt);
              var avgCtx = document.getElementById('avgTicketTimelineChart');
              if (avgCtx) {
                new Chart(avgCtx, {
                  type: 'line',
                  data: {
                    labels: labelShort,
                    datasets: [{
                      label: 'Ticket médio (R$)',
                      data: Array.isArray(data.dailyAvgTicket) ? data.dailyAvgTicket : [],
                      borderColor: '#2563eb',
                      backgroundColor: 'rgba(37, 99, 235, 0.15)',
                      tension: 0.3,
                      fill: true,
                      pointRadius: 2
                    }]
                  },
                  options: {
                    responsive: true,
                    plugins: { legend: { display: false } },
                    scales: {
                      y: { ticks: { stepSize: 5, callback: function(v){ return 'R$ ' + Number(v || 0).toFixed(2); } } }
                    }
                  }
                });
              }
              var salesCtx = document.getElementById('salesRevenueTimelineChart');
              if (salesCtx) {
                new Chart(salesCtx, {
                  type: 'line',
                  data: {
                    labels: labelShort,
                    datasets: [{
                      label: 'Faturamento (R$)',
                      data: Array.isArray(data.dailyRevenue) ? data.dailyRevenue : [],
                      borderColor: '#f59e0b',
                      backgroundColor: 'rgba(245, 158, 11, 0.15)',
                      tension: 0.3,
                      fill: true,
                      pointRadius: 2
                    }]
                  },
                  options: {
                    responsive: true,
                    plugins: { legend: { display: false } },
                    scales: {
                      y: { ticks: { callback: function(v){ return 'R$ ' + Number(v || 0).toFixed(0); } } }
                    }
                  }
                });
              }

              var pvRawEl = document.getElementById('paidValidatedSeriesData');
              var pvRaw = pvRawEl ? String(pvRawEl.textContent || '').trim() : '';
              var pv = pvRaw ? JSON.parse(pvRaw) : { labels: [], dailyPct: [], dailyPaid: [], dailyValidated: [] };
              var pvLabels = Array.isArray(pv.labels) ? pv.labels : [];
              var pvLabelShort = pvLabels.map(fmt);
              var pvCtx = document.getElementById('paidValidatedPctTimelineChart');
              if (pvCtx) {
                new Chart(pvCtx, {
                  type: 'line',
                  data: {
                    labels: pvLabelShort,
                    datasets: [{
                      label: '% pagos/validados',
                      data: Array.isArray(pv.dailyPct) ? pv.dailyPct : [],
                      borderColor: '#16a34a',
                      backgroundColor: 'rgba(22, 163, 74, 0.15)',
                      tension: 0.3,
                      fill: true,
                      pointRadius: 2
                    }]
                  },
                  options: {
                    responsive: true,
                    plugins: {
                      legend: { display: false },
                      tooltip: {
                        callbacks: {
                          label: function(ctx){
                            try {
                              var idx = Number(ctx.dataIndex || 0);
                              var paid = Array.isArray(pv.dailyPaid) ? Number(pv.dailyPaid[idx] || 0) : 0;
                              var val = Array.isArray(pv.dailyValidated) ? Number(pv.dailyValidated[idx] || 0) : 0;
                              return (Number(ctx.parsed && ctx.parsed.y ? ctx.parsed.y : 0).toFixed(1) + '% (' + paid + '/' + val + ')');
                            } catch (_) {
                              return (Number(ctx.parsed && ctx.parsed.y ? ctx.parsed.y : 0).toFixed(1) + '%');
                            }
                          }
                        }
                      }
                    },
                    scales: {
                      y: {
                        min: 0,
                        max: 100,
                        ticks: { callback: function(v){ return Number(v || 0).toFixed(0) + '%'; } }
                      }
                    }
                  }
                });
              }
            } catch (_) {}
          })();
        </script>
      </div>
      <% } %>
    <% } %>

    <% if (isRefil2View) { %>
      <div id="refil2RequestsWrap" style="margin-top: 14px; border:1px solid #e5e7eb; border-radius: 10px; padding: 14px; background: #fff; width:100%; box-sizing:border-box;">
        <div style="display:flex; justify-content:space-between; align-items:center; gap:10px; flex-wrap: wrap;">
          <strong style="font-size: 1rem; color:#111827;">Solicitações Refil2</strong>
          <div style="font-size:0.85rem; color:#6b7280;">Últimas solicitações</div>
        </div>
        <div class="panel-table-scroll" style="margin-top: 10px;">
          <table style="width:100%; border-collapse: collapse; font-size: 0.92rem; min-width: 860px;">
            <thead>
              <tr>
                <th style="text-align:left; padding:8px 6px; border-bottom:1px solid #e5e7eb;">Data/Hora</th>
                <th style="text-align:left; padding:8px 6px; border-bottom:1px solid #e5e7eb;">Data da compra</th>
                <th style="text-align:right; padding:8px 6px; border-bottom:1px solid #e5e7eb;">
                  <a href="#" class="refil2-sort" data-sort="days" style="color:inherit; text-decoration:none;">Dias<span id="refil2SortIconDays" style="margin-left:6px; color:#6b7280;"></span></a>
                </th>
                <th style="text-align:left; padding:8px 6px; border-bottom:1px solid #e5e7eb;">Perfil</th>
                <th style="text-align:left; padding:8px 6px; border-bottom:1px solid #e5e7eb;">Status</th>
                <th style="text-align:left; padding:8px 6px; border-bottom:1px solid #e5e7eb;">Mensagem</th>
              </tr>
            </thead>
            <tbody>
              <% 
                const r2 = Array.isArray(refil2Requests) ? refil2Requests : [];
                const fmtDate = (v) => {
                  try {
                    const d = (v instanceof Date) ? v : new Date(v || 0);
                    if (!Number.isFinite(d.getTime())) return '-';
                    try { return d.toLocaleString('pt-BR'); } catch (_) {}
                    const y = d.getFullYear();
                    const m = String(d.getMonth() + 1).padStart(2, '0');
                    const day = String(d.getDate()).padStart(2, '0');
                    const hh = String(d.getHours()).padStart(2, '0');
                    const mm = String(d.getMinutes()).padStart(2, '0');
                    const ss = String(d.getSeconds()).padStart(2, '0');
                    return `${day}/${m}/${y} ${hh}:${mm}:${ss}`;
                  } catch (_) { return '-'; }
                };
                const resolveStatus = (it) => {
                  const s = String(it && (it.execStatus || it.status || it.decisionStatus || it.decision) || '').toLowerCase().trim();
                  const err = String(it && (it.errorMessage || it.error || it.webhookMessage || it.decisionReason || it.statusMessage) || '').trim();
                  const ok = ['success','ok','done','reposto','repored'].includes(s) || (s === 'repor' && !err);
                  return { label: ok ? 'Sucesso' : 'Erro', cls: ok ? 'refil2-badge--green' : 'refil2-badge--red', msg: err || (ok ? 'OK' : '-') };
                };
              %>
              <% if (r2.length) { %>
                <% r2.slice(0, 200).forEach(it => { 
                  const when = fmtDate(it && (it.requestedAt || it.createdAt) ? (it.requestedAt || it.createdAt) : '');
                  const purchase = String(it && (it.purchaseAtLabel || it.purchaseAt) ? (it.purchaseAtLabel || fmtDate(it.purchaseAt)) : '-');
                  const reqRaw = it && (it.requestedAt || it.createdAt) ? (it.requestedAt || it.createdAt) : null;
                  const reqMs = reqRaw ? new Date(reqRaw).getTime() : 0;
                  const purRaw = it && it.purchaseAt ? it.purchaseAt : null;
                  const purMs = purRaw ? new Date(purRaw).getTime() : 0;
                  const dayDiff = (() => {
                    try {
                      if (!Number.isFinite(reqMs) || !reqMs) return null;
                      if (!Number.isFinite(purMs) || !purMs) return null;
                      const days = Math.floor((reqMs - purMs) / (24 * 60 * 60 * 1000));
                      if (!Number.isFinite(days)) return null;
                      return days;
                    } catch (_) { return null; }
                  })();
                  const user = String(it && it.username ? it.username : '-').trim();
                  const st = resolveStatus(it);
                %>
                  <tr data-refil2-days="<%= (dayDiff !== null ? String(dayDiff) : '') %>" data-refil2-whenms="<%= (Number.isFinite(reqMs) ? String(reqMs) : '') %>">
                    <td style="padding:8px 6px; border-bottom:1px solid #f3f4f6; color:#111827;"><%= when %></td>
                    <td style="padding:8px 6px; border-bottom:1px solid #f3f4f6; color:#111827;"><%= purchase %></td>
                    <td style="padding:8px 6px; border-bottom:1px solid #f3f4f6; color:#111827; text-align:right;"><%= (dayDiff !== null ? String(dayDiff) : '-') %></td>
                    <td style="padding:8px 6px; border-bottom:1px solid #f3f4f6; color:#111827;"><%= user ? ('@' + user.replace(/^@+/, '')) : '-' %></td>
                    <td style="padding:8px 6px; border-bottom:1px solid #f3f4f6;"><span class="refil2-badge <%= st.cls %>"><%= st.label %></span></td>
                    <td style="padding:8px 6px; border-bottom:1px solid #f3f4f6; color:#374151;"><%= st.msg %></td>
                  </tr>
                <% }) %>
              <% } else { %>
                <tr><td colspan="6" style="padding:10px 6px; color:#6b7280; text-align:center;">Sem solicitações ainda</td></tr>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>
      <script>
        (function(){
          function el(id){ return document.getElementById(id); }
          function sortRows(dir){
            try {
              var wrap = el('refil2RequestsWrap');
              if (!wrap) return;
              var tbody = wrap.querySelector('tbody');
              if (!tbody) return;
              var rows = Array.prototype.slice.call(tbody.querySelectorAll('tr'));
              if (!rows.length) return;
              rows.sort(function(a, b){
                var da = String(a.getAttribute('data-refil2-days') || '').trim();
                var db = String(b.getAttribute('data-refil2-days') || '').trim();
                var na = da === '' ? null : Number(da);
                var nb = db === '' ? null : Number(db);
                var aOk = (na !== null && isFinite(na));
                var bOk = (nb !== null && isFinite(nb));
                if (!aOk && !bOk) return 0;
                if (!aOk) return 1;
                if (!bOk) return -1;
                return (na - nb) * dir;
              });
              rows.forEach(function(r){ tbody.appendChild(r); });
            } catch (_) {}
          }
          var state = { dir: 'desc' };
          document.addEventListener('click', function(ev){
            try {
              var t = ev && ev.target ? ev.target : null;
              if (!t) return;
              var a = (t.closest && t.closest('.refil2-sort')) ? t.closest('.refil2-sort') : null;
              if (!a) return;
              ev.preventDefault();
              var next = (state.dir === 'asc') ? 'desc' : 'asc';
              state.dir = next;
              sortRows(next === 'asc' ? 1 : -1);
              var icon = el('refil2SortIconDays');
              if (icon) icon.textContent = (next === 'asc') ? '▲' : '▼';
            } catch (_) {}
          });
          try {
            var icon = el('refil2SortIconDays');
            if (icon) icon.textContent = '';
          } catch (_) {}
        })();
      </script>
    <% } %>

