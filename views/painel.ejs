          <script>
            (function(){
              var form = document.getElementById('costSettingsForm');
              if (!form) return;
              var toggleBtn = document.getElementById('toggleIgnoreBumpsBtn');
              if (toggleBtn) {
                var ignoreBumpsNow = String(toggleBtn.getAttribute('data-ignore-bumps') || '0') === '1';
                toggleBtn.style.background = ignoreBumpsNow ? '#6c757d' : '#dc3545';
                toggleBtn.addEventListener('click', function(){
                  try {
                    var url = new URL(window.location.href);
                    if (ignoreBumpsNow) url.searchParams.delete('ignoreBumps');
                    else url.searchParams.set('ignoreBumps', '1');
                    window.location.href = url.toString();
                  } catch (e) {
                    try { window.location.reload(); } catch(_) {}
                  }
                });
              }
              form.addEventListener('submit', function(ev){
                try {
                  ev.preventDefault();
                } catch(_) {}
                try {
                  var fd = new FormData(form);
                  var params = new URLSearchParams();
                  fd.forEach(function(value, key){
                    params.append(key, value);
                  });
                  fetch(form.action, {
                    method: 'POST',
                    body: params.toString(),
                    headers: {
                      'Accept': 'application/json',
                      'Content-Type': 'application/x-www-form-urlencoded; charset=UTF-8'
                    }
                  }).then(function(resp){
                    if (!resp.ok) return resp.text().then(function(t){ throw new Error(t || ('HTTP ' + resp.status)); });
                    return resp.json();
                  }).then(function(data){
                    alert('Custos atualizados com sucesso.');
                    try { window.location.reload(); } catch(_) {}
                  }).catch(function(err){
                    alert('Erro ao salvar custos: ' + (err && err.message ? err.message : err));
                  });
                } catch(e) {
                  alert('Erro inesperado ao enviar: ' + (e && e.message ? e.message : e));
                }
              });
            })();
          </script>
