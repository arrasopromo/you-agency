              </th>
              <th>
                <a href="#" class="followers-sort" data-sort="lastPurchaseAtMs" style="color:inherit; text-decoration:none;">Compra<span id="followersSortIconCompra" style="margin-left:6px; color:#6b7280;"></span></a>
              </th>
              <th>
                <a href="#" class="followers-sort" data-sort="currentCheckedAtMs" style="color:inherit; text-decoration:none;">Checado em<span id="followersSortIconChecked" style="margin-left:6px; color:#6b7280;"></span></a>
