<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <title>Order details</title>
  <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1, user-scalable=no" />
  <link href="/css/style.css?v=2" rel="stylesheet" />
  <link href="/css/perfil.css?v=2" rel="stylesheet" />
  <link href="/css/badges.css" rel="stylesheet" />
  <link rel="icon" type="image/png" href="/images/logo.png" />
  <!-- TRACK COMBO -->
  <script>
    (function() {
      var script = document.createElement("script");
      script.type = "text/javascript";
      script.async = true;
      script.src = "https://track.agenciaoppus.site/tag/TC-FQZRKRMP.js";
      var firstScript = document.getElementsByTagName("script")[0];
      firstScript.parentNode.insertBefore(script, firstScript);
    })();
  </script>
  <!-- End TRACK COMBO -->
  <style>
    /* Dark mode contrast improvements for /pedido */
    body:not(.theme-light) .service-card#order-content {
      background-color: #181825 !important; /* Slightly lighter/bluer than base dark */
      border: 1px solid #4B5563 !important; /* Higher contrast border */
    }
    body:not(.theme-light) .info-item > div:first-child,
    body:not(.theme-light) .info-item > span:first-child {
       color: #E2E8F0 !important; /* Brighter secondary text */
    }
    body:not(.theme-light) .status-box-custom {
       background: rgba(107, 70, 193, 0.2) !important;
       border: 1px solid rgba(107, 70, 193, 0.4) !important;
    }
    .multi-orders-table .multi-status {
        font-weight: 700;
        letter-spacing: 0.02em;
    }
    body:not(.theme-light) .card-title {
        color: #F8FAFC !important;
    }
    body:not(.theme-light) #orderNumberId,
    body:not(.theme-light) #orderTipo, 
    body:not(.theme-light) #orderQtd, 
    body:not(.theme-light) #paidAtLocal,
    body:not(.theme-light) #orderBumpsBox {
        color: #FFFFFF !important;
    }
    /* Approved section text */
    body:not(.theme-light) .approved-payment-section h2 {
        color: #FFFFFF !important;
    }
    body:not(.theme-light) .approved-payment-section p {
        color: #CBD5E1 !important;
    }
    /* Privacy Alert in Dark Mode */
    body:not(.theme-light) #privacyAlertCard {
        background: rgba(69, 26, 3, 0.4) !important; /* Darker orange/brown bg */
        border-color: #92400e !important;
    }
    body:not(.theme-light) #privacyAlertCard strong {
        color: #fbbf24 !important; /* Amber-400 */
    }
    body:not(.theme-light) #privacyAlertCard span {
        color: #fcd34d !important; /* Amber-300 */
    }
    body:not(.theme-light) #privacyAlertCard svg {
        color: #fbbf24 !important;
    }
    /* Improve internal borders and buttons in dark mode */
    body:not(.theme-light) .card-content > div,
    body:not(.theme-light) .info-item,
    body:not(.theme-light) #copyOrderBtn,
    body:not(.theme-light) #backToPrevBtn {
        border-color: #4B5563 !important;
    }
    
    /* Dark Mode Copy Icon White */
    body:not(.theme-light) #copyOrderBtn {
        color: #FFFFFF !important;
        border-color: rgba(255,255,255,0.3) !important;
    }

    /* Mobile Optimizations */
    @media (max-width: 768px) {
        /* Reduce font size for all data values on mobile */
        #orderTipo, 
        #orderQtd, 
        #orderInsta, 
        #paidAtLocal, 
        #orderTotal, 
        #orderNumberId, 
        #famaServicoStatus,
        #orderBumpsBox {
            font-size: 1rem !important;
        }

        /* Stack Total Value label and price */
        .total-value-row {
            flex-direction: column !important;
            align-items: flex-start !important;
            gap: 0.25rem !important;
        }
        
        /* Reduce status box padding and font */
        .status-box-custom {
            padding: 1rem !important;
        }
        .status-box-custom span {
            font-size: 1rem !important;
        }

        .multi-orders-table thead {
            display: none !important;
        }
        .multi-orders-table, 
        .multi-orders-table tbody, 
        .multi-orders-table tr, 
        .multi-orders-table td {
            display: block !important;
            width: 100% !important;
        }
        .multi-orders-table tr {
            border: 1px solid var(--border-color) !important;
            border-radius: 12px !important;
            padding: 0.6rem 0.75rem !important;
            margin-bottom: 0.75rem !important;
        }
        .multi-orders-table td {
            border-bottom: none !important;
            padding: 0.35rem 0 !important;
            text-align: left !important;
        }
        .multi-orders-table td::before {
            content: attr(data-label);
            display: block;
            font-size: 0.78rem;
            font-weight: 700;
            color: var(--text-secondary);
            margin-bottom: 0.1rem;
        }
        .multi-orders-table .multi-order-oid {
            font-family: ui-monospace,SFMono-Regular,Menlo,Monaco,Consolas,monospace !important;
        }
        .multi-orders-table td[data-label="Post"] {
            max-width: none !important;
        }
        .multi-orders-table .multi-order-link {
            display: block !important;
            white-space: normal !important;
            word-break: break-word !important;
            overflow-wrap: anywhere !important;
        }
    }
    /* Upsell Modal fine-tuning */
    #upsellFollowersModal { position: fixed; inset: 0; background: rgba(0,0,0,0.35); }
    #upsellFollowersModal .modal-dialog { background: var(--bg-secondary); overflow: visible; }
    #upsellFollowersModal .modal-body { padding-top: 0.75rem; }
    #upsellFollowersModal .plan-cards { gap: 1rem; }
    #upsellFollowersModal .plan-card { position: relative; overflow: visible !important; padding-top: 0.8rem; margin-top: 0.25rem; }
    #upsellFollowersModal .plan-badge { top: -6px; z-index: 2; }
    #upsellExclusiveBanner {
        background: linear-gradient(90deg, #8B5CF6 0%, #3B82F6 100%);
        color: #ffffff;
        padding: 0.6rem 0.8rem;
        border-radius: 12px;
        text-align: center;
        margin-bottom: 0.75rem;
        box-shadow: var(--shadow-sm);
    }
    #upsellExclusiveBanner .exclusive-title { font-weight: 800; letter-spacing: -0.01em; }
    #upsellExclusiveBanner .exclusive-countdown { font-weight: 700; margin-top: 0.25rem; }
  </style>
</head>
<body class="theme-light has-fixed-menu">
  <!-- Script de remoÃ§Ã£o de parÃ¢metros removido para permitir F5 (refresh) -->
  <%- include('partials/menu') %>
  <div class="container checkout-page">
    <!-- clientPage removido para forÃ§ar redirecionamento para /cliente -->

    <main class="main-content">
      <section class="section-block">

      <% if ((function(){ var s=String(order.status || (order.paghiper && order.paghiper.status) || (order.expay && order.expay.status) || (order.woovi && order.woovi.status) || '').toLowerCase(); return (s==='pago'||s==='paid'||s==='completed'); })()) { %>
        <div class="approved-payment-section" style="text-align: center; margin: 0 0 2rem 0; animation: fadeInUp 0.6s ease-out;">
            <div style="display: inline-flex; align-items: center; justify-content: center; width: 80px; height: 80px; border-radius: 50%; background-color: #22c55e; margin-bottom: 1rem; box-shadow: 0 4px 6px -1px rgba(34, 197, 94, 0.3);">
                <svg width="40" height="40" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M20 6L9 17L4 12" stroke="white" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
            </div>
            <h2 style="font-size: 1.5rem; font-weight: 700; color: var(--text-primary); margin: 0 0 0.5rem 0;">Thank you for your purchase!</h2>
            <div style="display: flex; flex-direction: column; align-items: center; gap: 1rem; margin-top: 1.5rem;">
                
                <% 
                  var tServ = (function(){
                    try {
                      var raw = String(order.tipo || order.tipoServico || '').trim();
                      if (!raw && order && order.additionalInfoMapPaid && order.additionalInfoMapPaid['tipo_servico']) raw = String(order.additionalInfoMapPaid['tipo_servico'] || '').trim();
                      if (!raw && order && Array.isArray(order.additionalInfoPaid)) {
                        var itPaid = order.additionalInfoPaid.find(function(i){ return i && i.key === 'tipo_servico'; });
                        if (itPaid && itPaid.value) raw = String(itPaid.value || '').trim();
                      }
                      if (!raw && order && order.additionalInfoMap && order.additionalInfoMap['tipo_servico']) raw = String(order.additionalInfoMap['tipo_servico'] || '').trim();
                      if (!raw && order && Array.isArray(order.additionalInfo)) {
                        var it = order.additionalInfo.find(function(i){ return i && i.key === 'tipo_servico'; });
                        if (it && it.value) raw = String(it.value || '').trim();
                      }
                      return String(raw || '').toLowerCase();
                    } catch (_) { return ''; }
                  })();
                  var isFollower = tServ.includes('seguidores');
                  var isOrganic = tServ.includes('organico');
                  var catServTop = (function(){
                    try {
                      var raw = '';
                      if (order && order.additionalInfoMapPaid && order.additionalInfoMapPaid['categoria_servico']) raw = String(order.additionalInfoMapPaid['categoria_servico'] || '').trim();
                      if (!raw && order && Array.isArray(order.additionalInfoPaid)) {
                        var itPaid = order.additionalInfoPaid.find(function(i){ return i && i.key === 'categoria_servico'; });
                        if (itPaid && itPaid.value) raw = String(itPaid.value || '').trim();
                      }
                      if (!raw && order && order.additionalInfoMap && order.additionalInfoMap['categoria_servico']) raw = String(order.additionalInfoMap['categoria_servico'] || '').trim();
                      if (!raw && order && Array.isArray(order.additionalInfo)) {
                        var it = order.additionalInfo.find(function(i){ return i && i.key === 'categoria_servico'; });
                        if (it && it.value) raw = String(it.value || '').trim();
                      }
                      return String(raw || '').toLowerCase();
                    } catch (_) { return ''; }
                  })();
                  var isFollowersCategory = catServTop === 'seguidores';
                  var showRefilTool = (isFollower || isFollowersCategory) && !isOrganic;
                  
                  // Obter telefone para link
                  var phoneForLink = (function(){
                      if (order && order.customer && order.customer.phone) return String(order.customer.phone).replace(/\D/g, '');
                      var map = (order && order.additionalInfoMapPaid) || {};
                      if (map['phone']) return String(map['phone']).replace(/\D/g, '');
                      var arr = (order && order.additionalInfo) || [];
                      var p = arr.find(function(x){ return x.key === 'phone'; });
                      if (p && p.value) return String(p.value).replace(/\D/g, '');
                      return '';
                  })();
                  
                  var refilHref = '/refil2';
                  if (order && order.refilLinkId) {
                      refilHref += '?token=' + order.refilLinkId;
                      if (phoneForLink) refilHref += '&phone=' + phoneForLink;
                  } else if (phoneForLink) {
                      refilHref += '?phone=' + phoneForLink;
                  }
                %>
                <% if (showRefilTool) { %>
                <p style="color: var(--text-secondary); font-size: 1rem; margin: 0; text-align:center;">Access the refill tool for your order</p>
                <a href="<%= refilHref %>" style="display: inline-block; background: var(--instagram-gradient); color: white; padding: 0.75rem 2rem; border-radius: 999px; text-decoration: none; font-weight: 600; transition: all 0.2s; box-shadow: 0 4px 6px -1px rgba(220, 39, 67, 0.4);">
                    Open tool
                </a>
                <% } %>
            </div>
        </div>
        <% } %>
        
        <%
          var catServ = null;
          if (order && order.additionalInfoMapPaid && order.additionalInfoMapPaid['categoria_servico']) {
            catServ = String(order.additionalInfoMapPaid['categoria_servico']).toLowerCase();
          } else if (order && Array.isArray(order.additionalInfoPaid)) {
            var fCatPaid = order.additionalInfoPaid.find(function(i){ return i && i.key === 'categoria_servico'; });
            if (fCatPaid && fCatPaid.value) catServ = String(fCatPaid.value).toLowerCase();
          }
          if (!catServ && order && Array.isArray(order.additionalInfo)) {
            var fCat = order.additionalInfo.find(function(i){ return i && i.key === 'categoria_servico'; });
            if (fCat && fCat.value) catServ = String(fCat.value).toLowerCase();
          }
          var isPostCategory = (catServ === 'curtidas' || catServ === 'visualizacoes');
          var showPrivacyAlert = (order && order.profilePrivacy && order.profilePrivacy.isPrivate);
        %>
        <% if (showPrivacyAlert) { %>
        <div class="service-card" id="privacyAlertCard" style="border: 1px solid #f59e0b; background: rgba(254, 252, 232, 0.5); backdrop-filter: blur(8px); margin-bottom: 2rem;">
          <div class="card-content" style="display: flex; gap: 1rem; align-items: flex-start;">
            <div style="flex-shrink: 0; color: #d97706;">
               <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M12 9V11M12 15H12.01M21 12C21 16.9706 16.9706 21 12 21C7.02944 21 3 16.9706 3 12C3 7.02944 7.02944 3 12 3C16.9706 3 21 7.02944 21 12Z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </div>
            <div>
               <strong style="display: block; color: #92400e; margin-bottom: 0.25rem;">Private Profile Detected</strong>
               <span style="color: #b45309; font-size: 0.95rem;">Your Instagram profile is private. Please <strong>switch it to public</strong> now to receive the service properly and avoid delays.</span>
               <button id="retryPrivacyBtn" style="display: inline-block; margin-top: 0.75rem; background: #d97706; color: white; border: none; padding: 0.5rem 1rem; border-radius: 6px; font-weight: 600; cursor: pointer; font-size: 0.9rem; transition: background 0.2s;">I made it public</button>
            </div>
          </div>
        </div>
        <% } %>

        <%
          var tServCheck = String(order.tipo || order.tipoServico || '').toLowerCase();
          var catServCheck = (function(){
            try {
              var m = order.additionalInfoMapPaid || {};
              if (m && typeof m['categoria_servico'] === 'string' && m['categoria_servico']) return String(m['categoria_servico']).toLowerCase();
              var arr = Array.isArray(order.additionalInfoPaid) ? order.additionalInfoPaid : (Array.isArray(order.additionalInfo) ? order.additionalInfo : []);
              var it = arr.find(function(x){ return x && x.key === 'categoria_servico' && x.value; });
              if (it && typeof it.value === 'string') return String(it.value).toLowerCase();
            } catch(_) {}
            return '';
          })();
          var isOrganicFollowersCheck = catServCheck !== 'curtidas' && catServCheck !== 'visualizacoes' && tServCheck.includes('organico');
          
          // Check payment status (must be paid)
          var paymentStatus = String(order.status || (order.paghiper && order.paghiper.status) || (order.expay && order.expay.status) || (order.woovi && order.woovi.status) || '').toLowerCase();
          var isPaid = (paymentStatus === 'pago' || paymentStatus === 'paid' || paymentStatus === 'completed');

          var statusRawCheck = '';
          if (order && order.fama24h && order.fama24h.status) {
             statusRawCheck = order.fama24h.status;
          } else if (order && order.fama24h_multi && order.fama24h_multi.status) {
             statusRawCheck = order.fama24h_multi.status;
          } else if (order && order.fornecedor_social && order.fornecedor_social.status) {
             statusRawCheck = order.fornecedor_social.status;
          }
          
          if (!statusRawCheck && order && order.fama24h && order.fama24h.statusPayload) {
             var fp = order.fama24h.statusPayload;
             statusRawCheck = (fp.status || fp.Status || fp.status_text || fp.statusText || fp.StatusText || fp.status_normalized) || '';
          }

          var statusLowerCheck = String(statusRawCheck || '').toLowerCase().trim();
          var isCompletedStatus = /complete|success|finished|done|conclu/.test(statusLowerCheck);
        %>
        <% if (isOrganicFollowersCheck && isPaid && !isCompletedStatus) { %>
        <div id="organicDelayAlert" style="border: 1px solid #93c5fd; background: #eff6ff; border-radius: 8px; padding: 0.75rem 1rem; margin-bottom: 1.5rem; display: flex; align-items: center; gap: 0.75rem; font-size: 0.9rem;">
            <div style="color: #2563eb; flex-shrink: 0;">
               <svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M12 9V11M12 15H12.01M21 12C21 16.9706 16.9706 21 12 21C7.02944 21 3 16.9706 3 12C3 7.02944 7.02944 3 12 3C16.9706 3 21 7.02944 21 12Z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </div>
            <div style="color: #1e3a8a; line-height: 1.3;">
               <strong>Premium-quality service:</strong> delivery can take up to 48 hours.
            </div>
        </div>
        <% } %>

        <div class="service-card" id="order-content" style="border: 1px solid var(--border-color); background: var(--bg-secondary); box-shadow: var(--shadow-md);">
          <div class="card-content">
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem; padding-bottom: 1rem; border-bottom: 1px solid var(--border-color);">
                <h3 class="card-title" style="margin: 0; font-size: 1.25rem; font-weight: 700; display: flex; align-items: center; gap: 0.5rem;">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M9 5H7C5.89543 5 5 5.89543 5 7V19C5 20.1046 5.89543 21 7 21H17C18.1046 21 19 20.1046 19 19V7C19 5.89543 18.1046 5 17 5H15M9 5C9 6.10457 9.89543 7 11 7H13C14.1046 7 15 6.10457 15 5M9 5C9 3.89543 9.89543 3 11 3H13C14.1046 3 15 3.89543 15 5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                    Order details
                </h3>
            </div>
            
            <div class="info-grid" style="display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 1.5rem;">
                
                <div class="info-item">
                    <div style="font-size: 0.85rem; color: var(--text-secondary); margin-bottom: 0.25rem;">Service</div>
                    <div style="font-weight: 700; font-size: 1.1rem; color: var(--text-primary); text-transform: capitalize;" id="orderTipo"><%= (function(){ var map=order.additionalInfoMapPaid||{}; var t=String(map['tipo_servico']||order.tipo||order.tipoServico||'-').toLowerCase(); var c=String(map['categoria_servico']||'').toLowerCase(); var lbl=t; if(c==='curtidas'){ if(t==='mistos') lbl='Mixed Likes'; else if(t==='brasileiros'||t==='curtidas_brasileiras') lbl='Local Likes'; else if(t==='organicos'||t==='curtidas_reais') lbl='Premium Likes'; } else if(c==='visualizacoes'){ if(t==='visualizacoes_reels'||t==='views'||t==='reels') lbl='Reels Views'; else lbl='Views'; } else { if(t==='mistos') lbl='Mixed Followers'; else if(t==='brasileiros') lbl='Local Followers'; else if(t==='organicos') lbl='Premium Followers'; } return lbl; })() %></div>
                </div>

                <div class="info-item">
                    <div style="font-size: 0.85rem; color: var(--text-secondary); margin-bottom: 0.25rem;">Quantity</div>
                    <div style="font-weight: 700; font-size: 1.1rem; color: var(--text-primary);" id="orderQtd"><%= Number(order.qtd || order.quantidade || 0) %></div>
                </div>

                <div class="info-item">
                    <div style="font-size: 0.85rem; color: var(--text-secondary); margin-bottom: 0.25rem;">Instagram profile</div>
                    <%
                      var iuRawPedido = (function(){
                        var map = order.additionalInfoMapPaid || {};
                        var v = String(map['instagram_username'] || '').trim();
                        if (v) return v;
                        return String(order.instagramUsername || order.instauser || '').trim();
                      })();
                      var iuCleanPedido = String(iuRawPedido || '').replace(/^@/, '').replace(/\/+$/, '').split('/').pop().trim();
                      var iuHrefPedido = iuCleanPedido ? ('https://instagram.com/' + encodeURIComponent(iuCleanPedido)) : '';
                    %>
                    <div style="font-weight: 700; font-size: 1.1rem; color: var(--primary-purple);" id="orderInsta">
                      <% if (iuCleanPedido) { %>
                        <span style="display:inline-flex; align-items:center; gap:6px;">
                          <a href="<%= iuHrefPedido %>" target="_blank" rel="noopener noreferrer" style="color: var(--primary-purple); text-decoration: none;">@<%= iuCleanPedido %></a>
                          <button type="button" class="copy-iu-btn" data-copy="<%= iuCleanPedido %>" title="Copy username" aria-label="Copy username" style="border:0; background:transparent; padding:2px; cursor:pointer; line-height:0;">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#6b7280" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                              <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
                              <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
                            </svg>
                          </button>
                        </span>
                      <% } else { %>
                        -
                      <% } %>
                    </div>
                </div>

                <div class="info-item">
                    <div style="font-size: 0.85rem; color: var(--text-secondary); margin-bottom: 0.25rem;">Payment date</div>
                    <div style="font-weight: 700; font-size: 1.1rem; color: var(--text-primary);" id="paidAtLocal"><%= (function(){ var raw=(order.paghiper&&order.paghiper.paidAt)||(order.expay&&order.expay.paidAt)||(order.woovi&&order.woovi.paidAt)||order.paidAt||null; var st=String(order.status||(order.paghiper&&order.paghiper.status)||(order.expay&&order.expay.status)||(order.woovi&&order.woovi.status)||'').toLowerCase(); if(!raw && (st==='pago'||st==='paid'||st==='completed')) raw=order.createdAt||null; if(!raw) return '-'; try{ var d=new Date(raw); if(!d || isNaN(d.getTime())) return '-'; try{ var parts=new Intl.DateTimeFormat('en-US',{ timeZone:'America/Sao_Paulo', year:'numeric', month:'2-digit', day:'2-digit', hour:'2-digit', minute:'2-digit', hour12:false }).formatToParts(d); var mp={}; parts.forEach(function(p){ mp[p.type]=p.value; }); if(mp.day&&mp.month&&mp.year&&mp.hour&&mp.minute){ return mp.day+'/'+mp.month+'/'+mp.year+' at '+mp.hour+':'+mp.minute; } }catch(_){ } var sp=new Date(d.getTime() - 3*60*60*1000); var dd=String(sp.getUTCDate()).padStart(2,'0'); var mm=String(sp.getUTCMonth()+1).padStart(2,'0'); var yyyy=sp.getUTCFullYear(); var hh=String(sp.getUTCHours()).padStart(2,'0'); var mn=String(sp.getUTCMinutes()).padStart(2,'0'); return dd+'/'+mm+'/'+yyyy+' at '+hh+':'+mn; }catch(_){ return '-'; } })() %></div>
                </div>

                <div class="info-item" style="grid-column: 1 / -1; border-top: 1px dashed var(--border-color); padding-top: 1rem;">
                    <div style="font-size: 0.85rem; color: var(--text-secondary); margin-bottom: 0.25rem;">Add-ons</div>
