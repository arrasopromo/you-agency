        if (navigator && navigator.clipboard && typeof navigator.clipboard.writeText === 'function') {
          return navigator.clipboard.writeText(v);
        }
        return new Promise(function(resolve, reject){
          try {
            var ta = document.createElement('textarea');
            ta.value = v;
            ta.setAttribute('readonly', 'readonly');
            ta.style.position = 'fixed';
            ta.style.top = '-1000px';
            ta.style.left = '-1000px';
            document.body.appendChild(ta);
            ta.select();
            var ok = document.execCommand('copy');
            document.body.removeChild(ta);
            if (ok) resolve();
            else reject(new Error('copy_failed'));
          } catch (e) {
            reject(e);
          }
        });
      }
      document.addEventListener('click', function(e){
        var btn = e && e.target ? e.target.closest('.copy-iu-btn') : null;
        if (!btn) return;
        var v = String(btn.getAttribute('data-copy') || '').replace(/^@/, '').trim();
        copyTextToClipboard(v).catch(function(){});
      });
    })();
    (function forceProviderStatusOnLoad(){
      try {
        var mapLabel = function(raw){
          var t = String(raw || '').trim().toLowerCase();
          if (!t) return '';
          if (/cancel/.test(t)) return 'Canceled';
          if (/partial/.test(t)) return 'Partial';
          if (/pend/.test(t)) return 'Pending';
          if (/process|progress|start|running|created/.test(t)) return 'In progress';
          if (/complete|success|finished|done|conclu/.test(t)) return 'Completed';
          return '';
        };
        var getRawStatus = function(x){
          try {
            var data = x && x.data ? x.data : null;
            var raw = data ? String(data.status || data.Status || data.status_text || data.statusText || data.StatusText || '').trim() : '';
            if (!raw && x && x.normalized) raw = String(x.normalized).trim();
            return raw;
          } catch(_) {}
          return '';
        };
        var setBadge = function(label){
          var el = document.getElementById('famaServicoStatus');
          if (!el) return;
          if (!label) return;
          el.textContent = label;
          try {
            el.classList.remove('status-green','status-yellow','status-red','status-blue');
            var s = label.toLowerCase();
            if (/completed|conclu/.test(s)) el.classList.add('status-green');
            else if (/cancel/.test(s)) el.classList.add('status-red');
            else if (/in\s+progress|andament|process|progress|start|running/.test(s)) el.classList.add('status-yellow');
            else if (/pend/.test(s)) el.classList.add('status-blue');
          } catch(_) {}
        };
        var extractOidsFromDom = function(){
          var ids = [];
          try {
            var trs = document.querySelectorAll('tr[data-provider-orderid]');
            for (var i=0; i<trs.length; i++){
              var v = String(trs[i].getAttribute('data-provider-orderid') || '').trim();
              if (!v) continue;
              if (ids.indexOf(v) === -1) ids.push(v);
            }
          } catch(_) {}
          try {
            var elOids = document.getElementById('orderNumberId');
            var txtOids = (elOids && elOids.textContent) ? String(elOids.textContent).trim() : '';
            if (txtOids && txtOids !== '-' && txtOids.toLowerCase() !== 'unknown') {
              var parts = txtOids.split(',').map(function(x){ return String(x || '').trim(); }).filter(Boolean);
              for (var p=0; p<parts.length; p++){
                var s = parts[p];
                if (ids.indexOf(s) === -1) ids.push(s);
              }
            }
          } catch(_) {}
          return ids;
        };
        var getStatusCls = function(label){
          var t = String(label || '').toLowerCase();
          if (/completed|conclu/.test(t)) return 'status-green';
          if (/cancel/.test(t)) return 'status-red';
          if (/in\s+progress|andament|process|progress|start|running/.test(t)) return 'status-yellow';
          if (/pend/.test(t)) return 'status-blue';
          return '';
        };
        var escHtml = function(s){
          return String(s || '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;').replace(/'/g,'&#39;');
        };
        var rowSet = function(oid, label){
          try {
            var tr = document.querySelector('tr[data-provider-orderid="' + String(oid) + '"]');
            var td = tr ? tr.querySelector('.multi-order-status') : null;
            if (td) {
              var lb = String(label || '-');
              var cls = getStatusCls(lb);
              td.innerHTML = '<span class="multi-status ' + String(cls || '') + '">' + escHtml(lb) + '</span>';
            }
          } catch(_){}
        };
        var decideOverall = function(labels){
          var arr = (labels || []).filter(function(x){ return !!x && String(x).trim() && String(x).trim() !== '-'; }).map(function(x){ return String(x).trim(); });
          if (!arr.length) return '';
          var allDone = arr.every(function(x){ return x === 'Completed'; });
          if (allDone) return 'Completed';
          var anyProgress = arr.some(function(x){ return x === 'In progress'; });
          if (anyProgress) return 'In progress';
          var anyPending = arr.some(function(x){ return x === 'Pending'; });
          if (anyPending) return 'Pending';
          var allCanceled = arr.every(function(x){ return x === 'Canceled'; });
          if (allCanceled) return 'Canceled';
          return 'Partial';
        };
        var fetchOne = function(oid){
          var url = '/api/order/provider-status?order=' + encodeURIComponent(String(oid));
          return fetch(url, { method: 'GET', cache: 'no-store' })
            .then(function(r){ return r.json(); })
            .then(function(x){
              var raw = getRawStatus(x);
              var label = mapLabel(raw) || '-';
              rowSet(oid, label);
              return label;
            })
            .catch(function(){
              rowSet(oid, '-');
              return '-';
            });
        };
        var pollMulti = function(){
          var ids = extractOidsFromDom();
          if (!ids.length) return false;
          Promise.all(ids.map(fetchOne)).then(function(labels){
            var overall = decideOverall(labels);
            if (overall) setBadge(overall);
          }).catch(function(){});
          return true;
        };

        if (pollMulti()) {
          try { setTimeout(pollMulti, 5000); } catch(_) {}
          try { setInterval(pollMulti, 120000); } catch(_) {}
          return;
        }

        var qs = new URLSearchParams((location && location.search) || '');
        var identParam = String(qs.get('identifier') || qs.get('t') || '').trim();
        var corrParam = String(qs.get('correlationID') || qs.get('ref') || '').trim();
        var orderParam = String(qs.get('orderID') || qs.get('orderid') || qs.get('oid') || '').trim();
        var url = '';
        if (identParam) url = '/api/order/provider-status?id=' + encodeURIComponent(identParam);
        else if (corrParam) url = '/api/order/provider-status?id=' + encodeURIComponent(corrParam);
        else if (orderParam) url = '/api/order/provider-status?order=' + encodeURIComponent(orderParam);
        if (!url) return;
        fetch(url, { method: 'GET', cache: 'no-store' })
          .then(function(r){ return r.json(); })
          .then(function(x){
            try {
              var raw = getRawStatus(x);
              var label = mapLabel(raw);
              setBadge(label);
            } catch(_) {}
          })
          .catch(function(){});
      } catch(_) {}
    })();
    (function initBackButton(){
      var btn = document.getElementById('backToPrevBtn');
      if (!btn) return;
      btn.addEventListener('click', function(){
        try {
          if (window.history && window.history.length > 1) { window.history.back(); return; }
        } catch(_) {}
        try {
          var phone = localStorage.getItem('oppus_client_phone') || '';
          if (phone) { window.location.href = '/cliente'; return; }
        } catch(_) {}
        window.location.href = '/checkout';
      });
    })();
  </script>

<!-- Privacy Check Modal -->
<div id="privacyModal" style="display:none; position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.8); z-index:99999; align-items:center; justify-content:center; padding:1rem; backdrop-filter: blur(5px);">
  <div style="background:var(--bg-secondary); padding:2rem; border-radius:16px; max-width:400px; width:100%; text-align:center; position:relative; box-shadow:0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 10px 10px -5px rgba(0, 0, 0, 0.04); border: 1px solid var(--border-color);">
    
    <!-- Step 1: Initial Warning -->
    <div id="privacyStep1">
      <div style="width:64px; height:64px; background:#FEF3C7; border-radius:50%; display:inline-flex; align-items:center; justify-content:center; margin-bottom:1.5rem; box-shadow: 0 4px 6px -1px rgba(245, 158, 11, 0.2);">
        <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#D97706" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"></path></svg>
      </div>
      <h3 style="margin:0 0 0.75rem 0; color:var(--text-primary); font-size: 1.25rem; font-weight: 700;">Private Profile Detected</h3>
      <div style="font-size: 1.2rem; color: var(--text-primary); margin-bottom: 1rem; font-weight: 600;">@<%= (function(){ var map=order.additionalInfoMapPaid||{}; var v=String(map['instagram_username']||'').trim(); if(v){ return v; } return String(order.instagramUsername || order.instauser || '-'); })() %></div>
      <p style="color:var(--text-secondary); margin-bottom:2rem; line-height: 1.5;">Switch your profile to public to receive the service. After changing it to public, come back here and click confirm so we can verify it.</p>
      <button id="btnConfirmPrivacy" onclick="checkPrivacyStatus()" class="continue-button" style="width:100%; justify-content:center; margin-top:1rem;">
        <span class="button-text">Confirm</span>
      </button>
    </div>

    <!-- Step 2: Loading -->
    <div id="privacyStepLoading" style="display:none; padding: 1rem 0;">
      <div class="spinner" style="border: 3px solid rgba(0,0,0,0.1); width: 48px; height: 48px; border-radius: 50%; border-left-color: #22c55e; animation: spin 1s linear infinite; margin: 0 auto 1.5rem;"></div>
      <h3 style="margin:0 0 0.5rem 0; color:var(--text-primary); font-size: 1.1rem;">Checking profile...</h3>
      <p style="color:var(--text-secondary);">Please wait a moment</p>
    </div>

    <!-- Step 3: Still Private (Timer) -->
    <div id="privacyStepError" style="display:none;">
      <div style="width:64px; height:64px; background:#FEE2E2; border-radius:50%; display:inline-flex; align-items:center; justify-content:center; margin-bottom:1.5rem;">
        <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#DC2626" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
      </div>
      <h3 style="margin:0 0 0.75rem 0; color:var(--text-primary); font-size: 1.25rem; font-weight: 700;">The profile is still private</h3>
      <div style="font-size: 1.2rem; color: var(--text-primary); margin-bottom: 1rem; font-weight: 600;">@<%= (function(){ var map=order.additionalInfoMapPaid||{}; var v=String(map['instagram_username']||'').trim(); if(v){ return v; } return String(order.instagramUsername || order.instauser || '-'); })() %></div>
      <p style="color:var(--text-secondary); margin-bottom:2rem; line-height: 1.5;">Your profile is still private. Switch it to public and come back here to confirm and finalize delivery.</p>
      
      <div style="font-size: 2rem; font-weight: 700; color: var(--text-primary); margin-bottom: 1.5rem; font-feature-settings: 'tnum'; font-variant-numeric: tabular-nums;">
        0:<span id="privacyTimer">59</span>
      </div>

      <button disabled style="width:100%; background:var(--bg-primary); color:var(--text-secondary); border:1px solid var(--border-color); padding:1rem; border-radius:12px; font-weight:600; cursor:not-allowed; font-size:1rem; opacity: 0.7;">
        Please wait...
      </button>
    </div>

  </div>
</div>

